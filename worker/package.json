{
  "name": "contentglowz-remotion-worker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.11.0",
  "description": "Internal Remotion render worker for ContentGlowz",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=8.11.0 <9"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "lint": "eslint . && tsc --noEmit",
    "test:storage": "tsx --test server/render-storage.test.ts",
    "test:timeline": "tsx --test remotion/timeline-schema.test.ts",
    "remotion:studio": "remotion studio"
  },
  "dependencies": {
    "@google-cloud/storage": "7.21.0",
    "@remotion/bundler": "4.0.482",
    "@remotion/cli": "4.0.482",
    "@remotion/renderer": "4.0.482",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.482",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.482",
    "@types/express": "5.0.1",
    "@types/react": "19.2.16",
    "eslint": "^9.39.1",
    "@types/node": "^26.0.0",
    "tsx": "^4.23.0",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "uuid": "11.1.1"
    }
  }
}
