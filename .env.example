# ⚠️  THIS FILE IS FOR LOCAL DEV FALLBACK ONLY
# ⚠️  PRODUCTION USES DOPPLER FOR SECRET MANAGEMENT
# 
# To configure secrets properly:
#   doppler secrets set KEY=value
#   OR use: https://dashboard.doppler.com
#
# This .env is only used when Doppler is not configured

# LLM API Keys

# RECOMMENDED: OpenRouter (50-90% cheaper, 100+ models, single API key)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Get free $5 credit: https://openrouter.ai/keys

# FALLBACK: Groq (FREE but limited models)
GROQ_API_KEY=your_groq_api_key_here
# Get your free key at: https://console.groq.com

# OPTIONAL: Direct APIs (only needed if not using OpenRouter)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Data Collection APIs
EXA_API_KEY=your_exa_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
SERP_API_KEY=your_serp_api_key_here

# STORM Research APIs (choose one for search)
YDC_API_KEY=your_you_api_key_here           # You.com API (recommended for STORM)
# SERPER_API_KEY=your_serper_api_key_here  # Alternative: Serper for Google results

# Email Service (Sending)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=your_email@example.com

# =============================================================================
# Newsletter Robot Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Email Backend Selection
# Options: "imap" (free, recommended) or "composio" (paid)
# -----------------------------------------------------------------------------
NEWSLETTER_EMAIL_BACKEND=imap

# -----------------------------------------------------------------------------
# IMAP Configuration (when NEWSLETTER_EMAIL_BACKEND=imap)
# Setup:
#   1. Enable 2FA on Gmail
#   2. Generate App Password at: Google Account → Security → App Passwords
#   3. Create Gmail labels: "Newsletters" and "Newsletters/Processed"
# -----------------------------------------------------------------------------
NEWSLETTER_IMAP_EMAIL=myrobot.newsletters@gmail.com
NEWSLETTER_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NEWSLETTER_IMAP_HOST=imap.gmail.com
NEWSLETTER_IMAP_FOLDER=Newsletters
NEWSLETTER_IMAP_ARCHIVE=Newsletters/Processed

# -----------------------------------------------------------------------------
# Composio Configuration (when NEWSLETTER_EMAIL_BACKEND=composio)
# Setup: composio add gmail
# -----------------------------------------------------------------------------
# COMPOSIO_API_KEY=your_composio_api_key_here

# -----------------------------------------------------------------------------
# Newsletter Output Settings
# -----------------------------------------------------------------------------
NEWSLETTER_FROM_EMAIL=newsletter@example.com
NEWSLETTER_FROM_NAME=My Newsletter

# =============================================================================
# Mem0 Memory Layer Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Selection: "local" (default, ChromaDB) or "hosted" (Mem0 Platform)
# -----------------------------------------------------------------------------
MEM0_BACKEND=local

# Hosted only — Mem0 Platform API key (https://app.mem0.ai)
# MEM0_API_KEY=your_mem0_api_key_here

# LLM for Mem0 fact extraction (default: gpt-4o-mini)
# MEM0_LLM_MODEL=gpt-4o-mini

# IMPORTANT: Embeddings require OpenAI API key (OpenRouter doesn't proxy embeddings)
# OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# =============================================================================
# Status Tracking Configuration
# =============================================================================
# STATUS_DB_PATH=data/status/status.db     # Local SQLite path (default)
# STATUS_SYNC_INTERVAL=30                   # Sync interval in seconds (default: 30)

# =============================================================================
# Image Robot Configuration (Robolly + Bunny.net)
# =============================================================================

# -----------------------------------------------------------------------------
# Robolly API (Image Generation)
# Get your API key at: https://robolly.com/dashboard
# -----------------------------------------------------------------------------
ROBOLLY_API_KEY=your_robolly_api_key_here

# Template IDs (create these in Robolly dashboard)
ROBOLLY_TEMPLATE_HERO=your_hero_template_id
ROBOLLY_TEMPLATE_SECTION=your_section_template_id
ROBOLLY_TEMPLATE_OG=your_og_card_template_id
ROBOLLY_TEMPLATE_THUMBNAIL=your_thumbnail_template_id

# -----------------------------------------------------------------------------
# Bunny.net CDN (Image Storage & Delivery)
# Get your API keys at: https://dash.bunny.net/account/apikey
# -----------------------------------------------------------------------------
BUNNY_STORAGE_API_KEY=your_bunny_storage_api_key
BUNNY_CDN_API_KEY=your_bunny_cdn_api_key
BUNNY_STORAGE_ZONE=my-robots-images
BUNNY_CDN_HOSTNAME=your-zone.b-cdn.net
BUNNY_PULL_ZONE_ID=123456
BUNNY_STORAGE_REGION=de

# -----------------------------------------------------------------------------
# Brand Configuration (for Robolly templates)
# -----------------------------------------------------------------------------
BRAND_COLOR_PRIMARY=#2563eb
BRAND_COLOR_SECONDARY=#64748b
BRAND_LOGO_URL=https://your-cdn.com/logo.png
