---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="/" class="logo">
          <span class="logo-icon">🤖</span>
          <span class="logo-text">ContentGlowz</span>
        </a>
        <p class="tagline">AI content pipeline. Swipe to publish.</p>
        <!-- Social links: add real URLs when available -->
      </div>

      <div class="footer-links">
        <div class="link-column">
          <h4>Product</h4>
          <ul>
            <li><a href="#robots">Robots</a></li>
            <li><a href="#features">Features</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#testimonials">Testimonials</a></li>
          </ul>
        </div>

        <div class="link-column">
          <h4>Resources</h4>
          <ul>
            <li><a href="/blog">Blog</a></li>
          </ul>
        </div>

        <div class="link-column">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 ContentGlowz. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
        padding: var(--space-16) 0 var(--space-8);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-16);
    margin-bottom: var(--space-12);
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-h3);
    font-weight: 800;
    color: var(--color-text-on-dark);
    margin-bottom: var(--space-4);
  }

  .logo-icon {
    font-size: var(--text-h2);
  }

  .tagline {
    color: var(--color-text-on-dark-muted);
    margin-bottom: var(--space-6);
    line-height: var(--leading-normal);
  }

  .social-links {
    display: flex;
    gap: var(--space-4);
  }

  .social-links a {
    inline-size: var(--space-10);
    block-size: var(--space-10);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-overlay-dark);
    border-radius: var(--radius-sm);
    color: var(--color-text-on-dark);
    transition: background var(--duration-slow), transform var(--duration-slow);
  }

  .social-links a:hover {
    background: var(--color-primary);
    transform: translateY(calc(var(--space-1) * -0.75));
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .link-column h4 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text-on-dark);
  }

  .link-column ul {
    list-style: none;
  }

  .link-column li {
    margin-bottom: var(--space-3);
  }

  .link-column a {
    color: var(--color-text-on-dark-muted);
    transition: color var(--duration-slow);
  }

  .link-column a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    border-top: calc(var(--space-1) / 4) solid var(--color-border-dark-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: var(--color-text-on-dark-faint);
    font-size: var(--text-sm);
  }

  .footer-bottom-links {
    display: flex;
    gap: var(--space-8);
  }

  .footer-bottom-links a {
    color: var(--color-text-on-dark-faint);
    font-size: var(--text-sm);
    transition: color var(--duration-slow) var(--ease-standard);
  }

  .footer-bottom-links a:hover {
    color: var(--color-text-on-dark);
  }

  @media (max-width: var(--breakpoint-md-max)) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }

    .footer-bottom-links {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
