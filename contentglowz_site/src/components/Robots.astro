---
import type { RobotsContent } from '../data/homepageContent';

interface Props {
  content: RobotsContent;
}

const { content } = Astro.props;
---

<section id="robots" class="robots-section">
  <div class="container">
    <div class="section-header">
      <h2>{content.intro.title}</h2>
      <p>{content.intro.description}</p>
    </div>

    <div class="robots-grid">
      {content.steps.map((step, index) => (
        <div class:list={['robot-card', { featured: Boolean(step.badge) }]}>
          {step.number && <div class="step-number">{step.number}</div>}
          {step.badge && <div class="featured-badge">{step.badge}</div>}
          <div class="robot-card-header card-title-row">
            <h3>{step.title}</h3>
            <div class="robot-icon card-title-icon">{step.icon}</div>
          </div>
          <p class="robot-tagline">{step.tagline}</p>
          <ul class="robot-features">
            {step.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .robots-section {
        padding: var(--space-24) 0;
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-surface-subtle) 100%);
  }

  .robots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(calc(var(--space-20) * 3.75), 1fr));
    gap: var(--space-8);
    margin-top: var(--space-12);
  }

  .robot-card {
    background: var(--color-surface);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--duration-slow), transform var(--duration-slow);
    position: relative;
  }

  .robot-card:hover {
    transform: translateY(var(--motion-lift-card));
    box-shadow: var(--shadow-card-lg);
  }

  .robot-card.featured {
    border: calc(var(--space-1) * 0.75) solid var(--color-primary);
    transform: scale(var(--card-featured-scale));
  }

  .step-number {
    position: absolute;
    top: calc(var(--space-4) * -1);
    left: var(--space-5);
    width: var(--space-10);
    height: var(--space-10);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: var(--text-base);
  }

  .featured-badge {
    position: absolute;
    top: calc(var(--space-4) * -1);
    right: var(--space-5);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
        padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-xl);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .robot-card-header {
    margin-bottom: var(--space-2);
  }

  .robot-icon {
    display: inline-flex;
    width: calc(var(--space-8) + var(--space-1));
    height: calc(var(--space-8) + var(--space-1));
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-surface-card-glass) 82%, transparent);
    box-shadow: inset 0 0 var(--space-1) color-mix(in srgb, var(--color-white) 24%, transparent);
    font-size: var(--text-h3);
  }

  @media (prefers-reduced-motion: no-preference) {
    .robot-icon {
      animation: emoji-bounce 4.2s ease-in-out infinite;
    }

    .robot-card:nth-child(1) .robot-icon {
      animation-delay: 0.15s;
    }

    .robot-card:nth-child(2) .robot-icon {
      animation-delay: 0.55s;
    }

    .robot-card:nth-child(3) .robot-icon {
      animation-delay: 0.95s;
    }
  }

  @keyframes emoji-bounce {
    0%,
    100% {
      transform: translateY(0) rotate(0);
    }
    50% {
      transform: translateY(calc(var(--space-1) * -0.5)) rotate(-6deg);
    }
  }

  .robot-card h3 {
    font-size: var(--text-h3);
    color: var(--color-text-primary);
  }

  .robot-tagline {
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }

  .robot-features {
    list-style: none;
  }

  .robot-features li {
        padding: var(--space-2) 0;
    color: var(--color-text-primary);
    border-bottom: calc(var(--space-1) / 4) solid var(--color-border-subtle);
    font-size: var(--text-sm);
  }

  .robot-features li:last-child {
    border-bottom: none;
  }

  .robot-features li::before {
    content: "\2192  ";
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .robots-section {
            padding: var(--space-16) 0;
    }

    .robots-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      margin-top: var(--space-8);
    }

    .robot-card {
            padding: var(--space-6) var(--space-6) var(--space-6);
    }

    .robot-card.featured {
      transform: scale(1);
    }
  }
</style>
