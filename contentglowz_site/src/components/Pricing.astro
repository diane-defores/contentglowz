---
import { appSignInUrl, creatorCheckoutUrl, proCheckoutUrl } from '../config/site';

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "ContentGlowz",
  "description": "AI content pipeline — generate, review, and publish multi-format content",
  "brand": { "@type": "Brand", "name": "ContentGlowz" },
  "offers": [
    {
      "@type": "Offer",
      "name": "Free",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "1 project, 5 content pieces/month, 1 publishing channel",
      "availability": "https://schema.org/InStock",
    },
    {
      "@type": "Offer",
      "name": "Creator",
      "price": "19",
      "priceCurrency": "EUR",
      "billingIncrement": 1,
      "description": "3 projects, 50 content pieces/month, all formats and channels, SEO keyword research",
      "availability": "https://schema.org/InStock",
    },
    {
      "@type": "Offer",
      "name": "Pro",
      "price": "49",
      "priceCurrency": "EUR",
      "billingIncrement": 1,
      "description": "Unlimited projects and content, competitor analysis, SERP tracking, API access",
      "availability": "https://schema.org/InStock",
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />
<section id="pricing" class="pricing-section">
  <div class="container">
    <div class="section-header">
      <h2>Simple Pricing. Start Free.</h2>
      <p>No credit card required. Upgrade when your content scales.</p>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card">
        <h3>Free</h3>
        <div class="price">
          <span class="amount">0</span>
          <span class="currency">&euro;</span>
        </div>
        <p class="billing-note">Forever free</p>

        <ul class="features">
          <li>1 project</li>
          <li>5 content pieces/month</li>
          <li>Swipe approval feed</li>
          <li>1 publishing channel</li>
          <li>Basic analytics</li>
          <li>Community support</li>
        </ul>
        <a class="cta-btn" href={appSignInUrl}>Get Started</a>
      </div>

      <div class="pricing-card featured">
        <div class="popular-badge">Most Popular</div>
        <h3>Creator</h3>
        <div class="price">
          <span class="amount">19</span>
          <span class="currency">&euro;</span>
          <span class="period">/mo</span>
        </div>
        <p class="billing-note">Everything you need to publish consistently</p>

        <ul class="features">
          <li>3 projects</li>
          <li>50 content pieces/month</li>
          <li>All 6 content formats</li>
          <li>All publishing channels</li>
          <li>SEO keyword research</li>
          <li>Affiliate link management</li>
          <li>Content scheduling</li>
          <li>Full analytics</li>
          <li>Email support</li>
        </ul>
        <a class="cta-btn primary" href={creatorCheckoutUrl}>
          Start 14-Day Trial
        </a>
      </div>

      <div class="pricing-card">
        <h3>Pro</h3>
        <div class="price">
          <span class="amount">49</span>
          <span class="currency">&euro;</span>
          <span class="period">/mo</span>
        </div>
        <p class="billing-note">For serious content creators and agencies</p>

        <ul class="features">
          <li>Unlimited projects</li>
          <li>Unlimited content</li>
          <li>All Creator features</li>
          <li>Competitor analysis</li>
          <li>Ranking position tracking</li>
          <li>Content strategy analysis</li>
          <li>Custom audience personas</li>
          <li>Priority support</li>
          <li>API access</li>
        </ul>
        <a class="cta-btn" href={proCheckoutUrl}>
          Start 14-Day Trial
        </a>
      </div>
    </div>

    <p class="pricing-note">All plans include AI generation costs, updates, and security patches. No hidden fees.</p>
  </div>
</section>

<style>
  .pricing-section {
    padding: var(--space-24) 0;
    background: linear-gradient(180deg, var(--color-surface-subtle) 0%, var(--color-surface) 100%);
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .pricing-card {
    background: var(--color-surface);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    position: relative;
    transition: transform var(--duration-slow), box-shadow var(--duration-slow);
  }

  .pricing-card:hover {
    transform: translateY(calc(var(--space-2) * -1));
    box-shadow: var(--shadow-card-lg);
  }

  .pricing-card.featured {
    border: 3px solid var(--color-primary);
    transform: scale(1.05);
  }

  .popular-badge {
    position: absolute;
    inset-block-start: calc(var(--space-4) * -1);
    inset-inline-start: 50%;
    translate: -50% 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .pricing-card h3 {
    font-size: var(--text-h3);
    margin-bottom: var(--space-6);
    color: var(--color-text-primary);
  }

  .price {
    display: flex;
    align-items: baseline;
    margin-bottom: var(--space-2);
  }

  .currency {
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-left: var(--space-1);
  }

  .amount {
    font-size: var(--text-h1);
    font-weight: 900;
    color: var(--color-text-primary);
  }

  .period {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-left: var(--space-1);
  }

  .billing-note {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }

  .features {
    list-style: none;
    margin-bottom: var(--space-8);
  }

  .features li {
    padding: var(--space-2) 0;
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-border-subtle);
    font-size: var(--text-base);
  }

  .features li:last-child {
    border-bottom: none;
  }

  .features li::before {
    content: "\2713  ";
    color: var(--color-primary);
    font-weight: 700;
  }

  .cta-btn {
    inline-size: 100%;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    background: var(--color-surface-subtle);
    color: var(--color-text-primary);
    transition: background var(--duration-slow) var(--ease-standard), color var(--duration-slow) var(--ease-standard), transform var(--duration-slow) var(--ease-standard), box-shadow var(--duration-slow) var(--ease-standard);
  }

  .cta-btn:hover {
    background: var(--color-text-primary);
    color: var(--color-surface);
  }

  .cta-btn.primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
  }

  .cta-btn.primary:hover {
    transform: translateY(calc(var(--space-1) * -0.5));
    box-shadow: var(--shadow-primary);
  }

  .pricing-note {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: var(--space-16) 0;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card.featured {
      transform: scale(1);
    }

    .pricing-card {
      padding: var(--space-8);
    }
  }
</style>
