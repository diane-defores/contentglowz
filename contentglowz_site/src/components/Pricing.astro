---
import { appSignInUrl, creatorCheckoutUrl, proCheckoutUrl } from '../config/site';
import type { PricingContent } from '../data/homepageContent';

interface Props {
  content: PricingContent;
}

const { content } = Astro.props;

const checkoutHrefByKey = {
  signIn: appSignInUrl,
  creatorCheckout: creatorCheckoutUrl,
  proCheckout: proCheckoutUrl,
} as const;

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "ContentGlowz",
  "description": "AI content pipeline — generate, review, and publish multi-format content",
  "brand": { "@type": "Brand", "name": "ContentGlowz" },
  "offers": content.plans.map((plan) => ({
    "@type": "Offer",
    "name": plan.name,
    "price": plan.price,
    "priceCurrency": plan.priceCurrency,
    ...(plan.billingIncrement ? { billingIncrement: plan.billingIncrement } : {}),
    "description": plan.schemaDescription,
    "availability": "https://schema.org/InStock",
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />
<section id="pricing" class="pricing-section">
  <div class="container">
    <div class="section-header">
      <h2>{content.intro.title}</h2>
      <p>{content.intro.description}</p>
    </div>

    <div class="pricing-grid">
      {content.plans.map((plan) => (
        <div class:list={['pricing-card', { featured: Boolean(plan.featured) }]}>
          {plan.badge && <div class="popular-badge">{plan.badge}</div>}
          <div class="pricing-card-head">
            <h3>{plan.name}</h3>
            <div class="pricing-summary">
              <div class="pricing-summary-chip">
                <div class="price">
                  <span class="amount">{plan.price}</span>
                  <span class="currency">&euro;</span>
                  {plan.period && <span class="period">{plan.period}</span>}
                </div>
              </div>
              <p class="billing-note">{plan.billingNote}</p>
            </div>
          </div>

          <div class="features-wrap">
            <ul class="features">
              {plan.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
          <div class="cta-wrap">
            <a class:list={['cta-btn', { primary: Boolean(plan.featured) }]} href={checkoutHrefByKey[plan.href]}>
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="pricing-note">{content.note}</p>
  </div>
</section>

<style>
  .pricing-section {
        padding: var(--space-24) 0;
    background: linear-gradient(180deg, var(--color-surface-subtle) 0%, var(--color-surface) 100%);
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--card-min-width), 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .pricing-card {
    background: var(--color-surface);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    transition: transform var(--duration-slow), box-shadow var(--duration-slow);
  }

  .pricing-card:hover {
    transform: translateY(calc(var(--space-2) * -1));
    box-shadow: var(--shadow-card-lg);
  }

  .pricing-card.featured {
    border: var(--card-featured-border-width) solid var(--color-primary);
    transform: scale(var(--card-featured-scale));
  }

  .popular-badge {
    position: absolute;
    inset-block-start: calc(var(--space-4) * -1);
    inset-inline-start: 50%;
    translate: -50% 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
        padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .pricing-card h3 {
    font-size: var(--text-h3);
    color: var(--color-text-primary);
  }

  .pricing-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .pricing-summary {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: var(--space-2);
  }

  .pricing-summary-chip {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    padding: var(--space-2) var(--space-4);
    border: calc(var(--space-1) * 0.5) solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-surface-subtle) 88%, transparent);
  }

  .price {
    display: flex;
    align-items: baseline;
    margin-bottom: var(--space-1);
  }

  .currency {
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-left: var(--space-1);
  }

  .amount {
    font-size: var(--text-h1);
    font-weight: 900;
    color: var(--color-text-primary);
  }

  .period {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-left: var(--space-1);
  }

  .billing-note {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  .features-wrap {
    margin-bottom: var(--space-4);
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .features {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }

  .features li {
        padding: var(--space-2) 0;
    color: var(--color-text-primary);
    border-bottom: calc(var(--space-1) / 4) solid var(--color-border-subtle);
    font-size: var(--text-base);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .features li:last-child {
    border-bottom: none;
  }

  .features li::before {
    content: "\2713  ";
    color: var(--color-primary);
    font-weight: 700;
  }

  .cta-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .cta-btn {
    inline-size: clamp(calc(var(--space-20) * 2.5), 58%, calc(var(--space-20) * 3.2));
    padding: var(--space-4);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    background: var(--color-surface-subtle);
    color: var(--color-text-primary);
    transition: background var(--duration-slow) var(--ease-standard), color var(--duration-slow) var(--ease-standard), transform var(--duration-slow) var(--ease-standard), box-shadow var(--duration-slow) var(--ease-standard);
  }

  .cta-btn:hover {
    background: var(--color-text-primary);
    color: var(--color-surface);
  }

  .cta-btn.primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
  }

  .cta-btn.primary:hover {
    transform: translateY(var(--motion-lift-sm));
    box-shadow: var(--shadow-primary);
  }

  .pricing-note {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .pricing-section {
            padding: var(--space-16) 0;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card.featured {
      transform: scale(1);
    }

    .pricing-card {
      padding: var(--space-8);
    }

    .pricing-card-head {
      flex-direction: column;
    }

    .pricing-summary {
      align-items: flex-start;
      text-align: left;
    }

    .features-wrap {
      justify-content: flex-start;
    }

    .features li {
      gap: var(--space-2);
    }

  .cta-wrap {
      justify-content: flex-end;
    }

    .pricing-summary-chip {
      width: 100%;
      align-items: flex-start;
      justify-content: flex-start;
      background: transparent;
      border-color: transparent;
      padding: 0;
    }

    .pricing-summary {
      width: 100%;
      align-items: stretch;
    }

    .pricing-summary .billing-note {
      margin-inline-start: 0;
    }

    .cta-btn {
      inline-size: min(calc(var(--space-20) * 2.9), var(--size-full));
    }
  }
</style>
