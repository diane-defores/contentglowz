---
import { appSignInUrl } from '../config/site';
---

<section class="closing-cta">
  <div class="container">
    <h2>Ready to turn ideas into reviewed content?</h2>
    <p>Start with a controlled workspace for ideas, drafts, review, scheduling, and supported publishing flows. Free plan, no credit card.</p>
    <div class="closing-cta-buttons">
      <a href={appSignInUrl} class="btn-primary">Start Free</a>
      <a href="/blog" class="btn-secondary">Read the Blog</a>
    </div>
    <p class="closing-note">
      Built for real-world conditions: degraded mode, local queue sync for supported edits, and explicit recovery after outages.
    </p>
  </div>
</section>

<style>
  .closing-cta {
    padding: var(--space-20) 0;
    text-align: center;
    background: var(--color-surface);
  }

  .container {
    max-width: 700px;
  }

  .closing-cta h2 {
    font-size: var(--text-h2);
    font-weight: 900;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .closing-cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .closing-cta-buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  .closing-note {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 640px;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .closing-cta {
      padding: var(--space-16) 0;
    }

    .closing-cta p {
      font-size: var(--text-base);
    }

    .closing-cta-buttons {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
      text-align: center;
    }
  }
</style>
