---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { siteUrl } from '../config/site';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'ai-agents'> | CollectionEntry<'platform'> | CollectionEntry<'seo-strategy'> | CollectionEntry<'startup-journey'> | CollectionEntry<'technical-optimization'> | CollectionEntry<'tutorials'>;
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, headings: renderedHeadings = [] } = Astro.props;
const { title, description, date, cover, byline, tags = [], featured } = post.data;

// Reading time: ~200 words/minute
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const headings = renderedHeadings.filter(
  (heading) => heading.depth === 2 || heading.depth === 3,
);
const hasToc = headings.length >= 3;

// Collection-aware section name and path
const collectionId = post.collection;
const sectionLabels: Record<string, string> = {
  blog: 'Blog',
  'ai-agents': 'AI Agents',
  platform: 'Platform',
  'seo-strategy': 'SEO Strategy',
  'startup-journey': 'Startup Journey',
  'technical-optimization': 'Technical Optimization',
  tutorials: 'Tutorials',
};
const sectionLabel = sectionLabels[collectionId] ?? 'Blog';
const sectionPath = `/${collectionId}`;

// Related posts: same collection, same tags, exclude self
const allPosts = await getCollection(collectionId as any, ({ data }: any) => !data.draft);
const related = allPosts
  .filter((p: any) => p.id !== post.id && p.data.tags?.some((t: string) => tags.includes(t)))
  .sort((a: any, b: any) => {
    const sharedA = a.data.tags?.filter((t: string) => tags.includes(t)).length ?? 0;
    const sharedB = b.data.tags?.filter((t: string) => tags.includes(t)).length ?? 0;
    return sharedB - sharedA;
  })
  .slice(0, 3);

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const resolvedSiteUrl = Astro.site?.toString().replace(/\/$/, '') ?? siteUrl;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": resolvedSiteUrl },
    { "@type": "ListItem", "position": 2, "name": sectionLabel, "item": `${resolvedSiteUrl}${sectionPath}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": `${resolvedSiteUrl}${sectionPath}/${post.id}` },
  ],
};
---

<Layout
  title={`${title} — ContentGlowz`}
  description={description}
  ogImage={cover ?? undefined}
  ogType="article"
  publishDate={date}
  author={byline}
  tags={tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Navbar />
  <header class="blog-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <a href={sectionPath}>{sectionLabel}</a>
    </nav>
  </header>

  <main id="main-content" class="blog-main">
    <article class="blog-article">
      <!-- Hero -->
      {cover && (
        <div class="hero-image">
          <img src={cover} alt={`Illustration for ${title}`} width="1200" height="630" />
        </div>
      )}

      <!-- Article header -->
      <div class="article-header">
        {tags.length > 0 && (
          <div class="tags">
            {tags.slice(0, 4).map((tag) => (
              <a href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag">
                {tag}
              </a>
            ))}
          </div>
        )}
        <h1>{title}</h1>
        <p class="article-description">{description}</p>
        <div class="article-meta">
          <span class="author">By {byline}</span>
          <span class="separator">·</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="separator">·</span>
          <span class="reading-time">{readingTime} min read</span>
        </div>
      </div>

      <!-- Layout: ToC + content -->
      <div class="article-body" class:list={[{ 'has-toc': hasToc }]}>
        {hasToc && (
          <aside class="toc">
            <p class="toc-title">Contents</p>
            <nav>
              <ol>
                {headings.map(({ depth, slug, text }) => (
                  <li class:list={[`toc-h${depth}`]}>
                    <a href={`#${slug}`}>{text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )}
        <div class="content prose">
          <slot />
        </div>
      </div>
    </article>

    <!-- Product CTA -->
    <CtaBanner />

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="related">
        <h2>Related articles</h2>
        <div class="related-grid">
          {related.map((rp) => (
            <a href={`${sectionPath}/${rp.id}`} class="related-card">
              {rp.data.cover && (
                <img src={rp.data.cover} alt={`Illustration for ${rp.data.title}`} width="400" height="210" />
              )}
              <div class="related-card-body">
                {rp.data.tags?.slice(0, 2).map((t) => (
                  <span class="tag">{t}</span>
                ))}
                <h3>{rp.data.title}</h3>
                <p>{rp.data.description}</p>
                <span class="read-more">Read article →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Back link -->
    <div class="back-link">
      <a href={sectionPath}>← Back to {sectionLabel}</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .blog-header {
    padding: var(--space-20) var(--space-8); var(--space-6);
    border-bottom: thin solid var(--color-light-gray);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
    max-width: calc(var(--container-max-width) - var(--space-20) * 4);
    margin: 0 auto;
  }

  .breadcrumb a:hover { color: var(--color-primary); }

  .blog-main {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-8); var(--space-16);
  }

  .blog-article { margin-bottom: var(--space-16); }

  .hero-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .hero-image img { width: var(--size-full); height: auto; display: block; }

  .article-header { margin-bottom: var(--space-10); }

  .tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4); }

  .tag {
    background: var(--color-light-gray);
    color: var(--color-gray);
    padding: calc(var(--space-1) * 0.8) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: lowercase;
    transition: background var(--duration-fast);
  }

  .tag:hover { background: var(--color-light-blue); color: var(--color-primary-dark); }

  .article-header h1 {
    font-size: var(--text-h1);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .article-description {
    font-size: var(--text-lg);
    color: var(--color-gray);
    margin-bottom: var(--space-5);
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
  }

  .separator { opacity: 0.4; }
  .reading-time { font-weight: 500; }

  /* Article body with optional ToC */
  .article-body {
    display: block;
  }

  .article-body.has-toc {
    --toc-width: calc(var(--space-20) * 3.25);

    display: grid;
    grid-template-columns: 1fr var(--toc-width);
    gap: var(--space-12);
    align-items: start;
  }

  /* On mobile: stack ToC below content */
  @media (max-width: var(--breakpoint-md-max)) {
    .article-body.has-toc {
      display: flex;
      flex-direction: column-reverse;
      gap: var(--space-8);
    }
  }

  .toc {
    position: sticky;
    top: var(--space-8);
    background: var(--color-light-gray);
    border-radius: var(--radius-md);
    padding: var(--space-5); var(--space-6);
    order: 2;
  }

  .toc-title {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-gray);
    margin-bottom: var(--space-3);
  }

  .toc nav ol {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-1) * 1.4);
  }

  .toc-h2 a, .toc-h3 a {
    font-size: var(--text-sm);
    color: var(--color-gray);
    display: block;
    padding: calc(var(--space-1) * 0.4) 0;
    transition: color var(--duration-fast);
    line-height: var(--leading-snug);
  }

  .toc-h3 { padding-left: var(--space-3); }
  .toc-h2 a:hover, .toc-h3 a:hover { color: var(--color-primary); }

  /* Prose styles */
  .prose {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    max-width: var(--size-prose);
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-3);
    scroll-margin-top: var(--space-20);
  }

  .prose :global(h2) { font-size: var(--text-h3); }
  .prose :global(h3) { font-size: var(--text-lg); }

  .prose :global(p) { margin-bottom: var(--space-5); }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    text-underline-offset: calc(var(--space-1) * 0.75);
  }

  .prose :global(a:hover) { text-decoration-color: var(--color-primary); }

  .prose :global(code) {
    background: var(--color-light-gray);
    padding: calc(var(--space-1) * 0.6) calc(var(--space-2) * 0.9);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
  }

  .prose :global(pre) {
    background: var(--color-dark);
    color: var(--color-code-text);
    padding: var(--space-5); var(--space-6);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
    line-height: var(--leading-readable);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: var(--space-1); solid var(--color-primary);
    padding-left: var(--space-5);
    color: var(--color-gray);
    font-style: italic;
    margin: var(--space-6); 0;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .prose :global(li) { margin-bottom: calc(var(--space-2) * 0.8); }

  .prose :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-6); 0;
    width: var(--size-full);
  }

  .prose :global(hr) {
    border: none;
    border-top: thin solid var(--color-light-gray);
    margin: var(--space-10); 0;
  }

  .prose :global(table) {
    width: var(--size-full);
    border-collapse: collapse;
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .prose :global(th), .prose :global(td) {
    border: thin solid var(--color-light-gray);
    padding: var(--space-2); var(--space-4);
    text-align: left;
  }

  .prose :global(th) { background: var(--color-light-gray); font-weight: 600; }

  /* Related posts */
  .related { margin-bottom: var(--space-12); }

  .related h2 {
    font-size: var(--text-h3);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: thin solid var(--color-light-gray);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(calc(var(--space-20) * 3.5), 1fr));
    gap: var(--space-6);
  }

  .related-card {
    border: thin solid var(--color-light-gray);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow var(--duration-base), transform var(--duration-base);
    display: flex;
    flex-direction: column;
  }

  .related-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(calc(var(--space-1) * -0.5));
  }

  .related-card img { width: var(--size-full); height: calc(var(--space-20) * 2); object-fit: cover; }

  .related-card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .related-card-body h3 {
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .related-card-body p {
    font-size: var(--text-sm);
    color: var(--color-gray);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .back-link a {
    color: var(--color-gray);
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }

  .back-link a:hover { color: var(--color-primary); }
</style>
