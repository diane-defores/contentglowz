---
import { siteUrl } from '../config/site';
import themeTokens from '../../../contentglowz_theme.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  publishDate?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = "AI content pipeline — generate, review, and publish multi-format content",
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  publishDate,
  author = 'ContentGlowz Team',
  tags = [],
  noindex = false,
} = Astro.props;

const resolvedSiteUrl = Astro.site?.toString().replace(/\/$/, '') ?? siteUrl;
const canonical = canonicalUrl ?? `${resolvedSiteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${resolvedSiteUrl}${ogImage}`;

const articleSchema = ogType === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImageAbsolute,
  "author": { "@type": "Person", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "ContentGlowz",
    "url": resolvedSiteUrl,
  },
  "datePublished": publishDate?.toISOString(),
  "keywords": tags.join(', '),
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
} : null;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ContentGlowz",
  "url": resolvedSiteUrl,
  "description": "AI content pipeline — generate, review, and publish multi-format content",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ContentGlowz",
  "url": resolvedSiteUrl,
};

const {
  colors,
  surfaces,
  typography,
  spacing,
  radius,
  shadow,
  motion,
  components,
  layout,
  breakpoints,
} = themeTokens;
const themeCssVars = `
  :root {
    color-scheme: light;
    --color-primary: ${colors.primary};
    --color-primary-dark: ${colors.primaryDark};
    --color-secondary: ${colors.secondary};
    --color-accent: ${colors.accent};
    --color-success: ${colors.success};
    --color-warning: ${colors.warning};
    --color-orange: ${colors.orange};
    --color-green: ${colors.green};
    --color-error: ${colors.error};
    --color-dark: ${colors.dark};
    --color-gray: ${colors.gray};
    --color-light-gray: ${colors.lightGray};
    --color-light-blue: ${colors.lightBlue};
    --color-white: ${colors.white};
    --color-canvas: ${surfaces.light.canvas};
    --color-surface-elevated: ${surfaces.light.elevatedSurface};
    --color-input-fill: ${surfaces.light.inputFill};
    --color-text-primary: var(--color-dark);
    --color-text-muted: var(--color-gray);
    --color-text-code: ${colors.codeText};
    --color-surface: ${surfaces.light.surface};
    --color-surface-subtle: ${surfaces.light.mutedSurface};
    --color-surface-tint: ${surfaces.light.surfaceTint};
    --color-surface-navbar: color-mix(in srgb, var(--color-surface-elevated) 95%, transparent);
    --color-surface-card-glass: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
    --color-border-subtle: ${surfaces.light.borderSubtle};
    --color-border-light: ${surfaces.light.borderLight};
    --color-border-dark-subtle: ${surfaces.dark.borderSubtle};
    --color-overlay-dark: color-mix(in srgb, var(--color-white) 10%, transparent);
    --color-text-on-dark: var(--color-white);
    --color-text-on-dark-muted: color-mix(in srgb, var(--color-white) 70%, transparent);
    --color-text-on-dark-faint: color-mix(in srgb, var(--color-white) 60%, transparent);
    --color-focus-ring: ${themeTokens.focus.ring};
    --color-code-text: ${colors.codeText};
    --color-badge-bg: ${colors.badgeBg};
    --color-badge-text: ${colors.badgeText};
    --font-sans: ${typography.fontSans};
    --font-main: var(--font-sans);
    --text-xs: ${typography.textXs};
    --text-sm: ${typography.textSm};
    --text-base: ${typography.textBase};
    --text-lg: ${typography.textLg};
    --text-h3: ${typography.textH3};
    --text-h2: ${typography.textH2};
    --text-h1: ${typography.textH1};
    --leading-tight: ${typography.leadingTight};
    --leading-snug: ${typography.leadingSnug};
    --leading-normal: ${typography.leadingNormal};
    --leading-relaxed: ${typography.leadingRelaxed};
    --tracking-wide: ${typography.trackingWide};
    --tracking-wider: ${typography.trackingWider};
    --space-0: ${spacing[0]};
    --space-1: ${spacing[1]};
    --space-2: ${spacing[2]};
    --space-3: ${spacing[3]};
    --space-4: ${spacing[4]};
    --space-5: ${spacing[5]};
    --space-6: ${spacing[6]};
    --space-8: ${spacing[8]};
    --space-10: ${spacing[10]};
    --space-12: ${spacing[12]};
    --space-16: ${spacing[16]};
    --space-20: ${spacing[20]};
    --space-24: ${spacing[24]};
    --space-mobile-2: ${spacing.mobile[2]};
    --space-mobile-3: ${spacing.mobile[3]};
    --space-mobile-4: ${spacing.mobile[4]};
    --space-mobile-5: ${spacing.mobile[5]};
    --space-mobile-6: ${spacing.mobile[6]};
    --space-mobile-8: ${spacing.mobile[8]};
    --space-mobile-10: ${spacing.mobile[10]};
    --space-mobile-scale: ${spacing.densityScale?.mobile};
    --space-density-scale: ${spacing.densityScale?.desktop};
    --radius-sm: ${radius.sm};
    --radius-md: ${radius.md};
    --radius-lg: ${radius.lg};
    --radius-xl: ${radius.xl};
    --radius-2xl: ${radius['2xl']};
    --radius-pill: ${radius.pill};
    --shadow-sm: ${shadow.sm};
    --shadow-card: ${shadow.card};
    --shadow-card-hover: ${shadow.cardHover};
    --shadow-card-lg: ${shadow.cardLg};
    --shadow-primary: ${shadow.primary};
    --shadow-primary-hover: ${shadow.primaryHover};
    --duration-instant: ${motion.instant};
    --duration-fast: ${motion.fast};
    --duration-base: ${motion.base};
    --duration-slow: ${motion.slow};
    --duration-motion-reduced: 0.01ms;
    --ease-standard: ${motion.standard};
    --ease-out: ${motion.out};
    --ease-spring: ${motion.spring};
    --container-max-width: ${layout.containerMaxWidth};
    --section-gap: ${layout.sectionGap};
    --hero-gap: ${layout.heroGap};
    --cta-width: ${layout.ctaWidth};
    --section-padding: ${components.card.padding};
    --card-radius: ${components.card.radius};
    --card-compact-radius: ${components.card.compactRadius};
    --card-compact-padding: ${components.card.compactPadding};
    --button-radius: ${components.button.radius};
    --button-padding-x: ${components.button.paddingX};
    --button-padding-y: ${components.button.paddingY};
    --button-compact-padding-y: ${components.button.compactPaddingY};
    --input-radius: ${components.input.radius};
    --input-radius-compact: ${components.input.radiusCompact};
    --radius-nav: ${components.nav.radius};
    --badge-radius: ${components.badge.radius};
    --size-full: 100%;
    --size-prose: 72ch;
    --height-screen: 100vh;
    --height-screen-half: 60vh;
    --z-index-sticky: 1001;
    --z-index-floating: 1000;
    --z-index-backdrop: -1;
    --hero-mobile-padding-y: calc(var(--space-20) + var(--space-2));
    --card-min-width: calc(var(--space-10) * 7);
    --testimonial-card-min-width: var(--space-20);
    --surface-backdrop-blur: blur(10px);
    --focus-outline-width: calc(var(--space-1) / 2);
    --motion-lift-tiny: calc(var(--space-1) * -0.5);
    --motion-lift-sm: calc(var(--space-1) * -0.75);
    --motion-lift-card: calc(var(--space-1) * -1.25);
    --card-featured-border-width: 3px;
    --card-featured-scale: 1.05;
    --leading-hero: 1.15;
    --leading-readable: 1.7;
    --leading-copy: 1.5;
    --tracking-superwide: 0.02em;
    --tracking-heading: 0.06em;
    --tracking-heading-tight: 0.05em;
    --width-content-narrow: 700px;
    --width-content-note: 640px;
    --breakpoint-mobile: ${breakpoints.mobile}px;
    --breakpoint-md-max: 768px;
    --breakpoint-compact-max: 700px;
    --breakpoint-narrow-max: 640px;
    --breakpoint-tablet: ${breakpoints.tablet}px;
    --breakpoint-desktop: ${breakpoints.desktop}px;
    --mobile-density-scale: ${spacing.densityScale?.mobile};
    --desktop-density-scale: ${spacing.densityScale?.desktop};
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --color-canvas: ${surfaces.dark.canvas};
    --color-surface: ${surfaces.dark.surface};
    --color-surface-elevated: ${surfaces.dark.elevatedSurface};
    --color-surface-subtle: ${surfaces.dark.mutedSurface};
    --color-input-fill: ${surfaces.dark.inputFill};
    --color-surface-tint: ${surfaces.dark.surfaceTint};
    --color-text-primary: color-mix(in srgb, var(--color-white) 97%, var(--color-surface));
    --color-text-muted: color-mix(in srgb, var(--color-white) 78%, var(--color-surface));
    --color-surface-navbar: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
    --color-surface-card-glass: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
    --color-border-subtle: ${surfaces.dark.borderSubtle};
    --color-border-light: ${surfaces.dark.borderLight};
    --color-focus-ring: ${themeTokens.focus.ringStrong};
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      color-scheme: dark;
      --color-canvas: ${surfaces.dark.canvas};
      --color-surface: ${surfaces.dark.surface};
      --color-surface-elevated: ${surfaces.dark.elevatedSurface};
      --color-surface-subtle: ${surfaces.dark.mutedSurface};
      --color-input-fill: ${surfaces.dark.inputFill};
      --color-surface-tint: ${surfaces.dark.surfaceTint};
      --color-text-primary: color-mix(in srgb, var(--color-white) 97%, var(--color-surface));
      --color-text-muted: color-mix(in srgb, var(--color-white) 78%, var(--color-surface));
      --color-surface-navbar: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
      --color-surface-card-glass: color-mix(in srgb, var(--color-surface-elevated) 94%, transparent);
      --color-border-subtle: ${surfaces.dark.borderSubtle};
      --color-border-light: ${surfaces.dark.borderLight};
      --color-focus-ring: ${themeTokens.focus.ringStrong};
    }
  }
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ContentGlowz" />
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

    <!-- Favicon & theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content={surfaces.light.canvas} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={surfaces.dark.canvas} media="(prefers-color-scheme: dark)" />
    <style is:global set:html={themeCssVars}></style>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- ContentGlowz Analytics (cookie-free, production only) -->
    {import.meta.env.PROD && (
      <script defer src="https://api.contentglowz.com/a/s.js"></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* =============================================
     CONTENTGLOWZ DESIGN TOKENS
     Single source of truth for all visual values
     ============================================= */
  /* =============================================
     BASE RESET & GLOBAL STYLES
     ============================================= */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    background-color: var(--color-canvas);
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  img {
    max-width: var(--size-full);
    height: auto;
  }

  /* --- Layout utilities --- */
  .container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .card-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .card-title-row h3 {
    margin: 0;
  }

  .card-title-icon {
    flex: 0 0 auto;
    font-size: var(--text-h2);
    line-height: var(--leading-tight);
  }

  @media (max-width: 600px) {
    .container {
      padding: 0 var(--space-mobile-4);
    }

    .section-header {
      margin-bottom: var(--section-gap);
    }

    .section-header p {
      font-size: calc(var(--text-base) * var(--mobile-density-scale));
    }
  }

  /* --- Button system --- */
  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
        padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    transition: transform var(--duration-base), box-shadow var(--duration-base);
    box-shadow: var(--shadow-primary);
    display: inline-block;
  }

  .btn-primary:hover {
    transform: translateY(var(--motion-lift-sm));
    box-shadow: var(--shadow-primary-hover);
  }

  .btn-secondary {
    background: var(--color-surface-elevated);
    color: var(--color-primary);
        padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    border: calc(var(--space-1) / 2) solid var(--color-primary);
    transition: background var(--duration-base), color var(--duration-base);
    display: inline-block;
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
  }

  /* --- Focus — WCAG 2.4.11 --- */
  :focus-visible {
    outline: var(--focus-outline-width) solid var(--color-focus-ring);
    outline-offset: var(--focus-outline-width);
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: var(--duration-motion-reduced) !important;
      animation-iteration-count: 1 !important;
      transition-duration: var(--duration-motion-reduced) !important;
    }

    html {
      scroll-behavior: auto;
    }
  }
</style>
