---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Robots from '../components/Robots.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import ClosingCta from '../components/ClosingCta.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ContentGlowz — Human-Led AI Content Workspace"
  description="ContentGlowz turns ideas into reviewed articles, newsletters, social posts, and video scripts with AI assistance, clear approval, scheduling, and supported publishing flows."
>
  <Navbar />
  <main class="landing-shell">
    <Hero />
    <Problem />
    <Robots />
    <Features />
    <Testimonials />
    <Pricing />
    <FAQ />
    <ClosingCta />
  </main>
  <Footer />
</Layout>

<style>
  .landing-shell > section + section {
    position: relative;
  }

  .landing-shell > section + section::before {
    content: "";
    position: absolute;
    inset-inline: var(--space-8);
    inset-block-start: calc(var(--space-1) * -1);
    inline-size: calc(100% - (var(--space-8) * 2));
    block-size: calc(var(--space-1) / 4);
    background: color-mix(in srgb, var(--color-surface) 82%, transparent);
    box-shadow: var(--shadow-card);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .landing-shell > section + section::before {
      inset-inline: var(--space-4);
      inline-size: calc(100% - (var(--space-4) * 2));
    }
  }
</style>
