---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import {
  filterBlogEntriesByLocale,
  formatBlogDate,
  getBlogIndexAlternates,
  getBlogLabels,
  getBlogPostPath,
} from '../../../data/blogContent';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = filterBlogEntriesByLocale(allPosts, 'fr').sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const labels = getBlogLabels('fr');
const blogMeta = getBlogIndexAlternates('fr');

const featured = posts.find((p) => p.data.featured);
const rest = posts.filter((p) => p.id !== featured?.id);
---

<Layout
  title="Blog — ContentGlowz"
  description={labels.blogDescription}
  ogType="website"
  locale="fr"
  canonicalUrl={blogMeta.canonicalUrl}
  alternateLocales={blogMeta.alternateLocales}
>
  <Navbar locale="fr" />

  <main id="main-content" class="blog-index">
    <div class="blog-header">
      <h1>{labels.blogTitle}</h1>
      <p>{labels.blogDescription}</p>
    </div>

    {featured && (
      <a href={getBlogPostPath(featured, 'fr')} class="featured-card">
        {featured.data.cover && (
          <img src={featured.data.cover} alt={`À la une : ${featured.data.title}`} width="800" height="420" />
        )}
        <div class="featured-body">
          <div class="featured-eyebrow">
            {featured.data.tags?.slice(0, 2).map((t) => (
              <span class="tag">{t}</span>
            ))}
            <span class="featured-badge">{labels.featured}</span>
          </div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="post-meta">
            <span>{featured.data.byline}</span>
            <span>·</span>
            <time datetime={featured.data.date.toISOString()}>
              {formatBlogDate(featured.data.date, 'fr', 'long')}
            </time>
          </div>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <section class="posts-section">
        <h2 class="section-title">{labels.allArticles}</h2>
        <div class="posts-grid">
          {rest.map((post) => (
            <a href={getBlogPostPath(post, 'fr')} class="post-card">
              {post.data.cover && (
                <img src={post.data.cover} alt={`Illustration pour ${post.data.title}`} width="400" height="210" />
              )}
              <div class="post-card-body">
                {post.data.tags?.slice(0, 2).map((t) => (
                  <span class="tag">{t}</span>
                ))}
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {formatBlogDate(post.data.date, 'fr', 'short')}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="empty-state">
        <p>{labels.noArticles}</p>
        <a href="/fr" class="btn">{labels.backHome}</a>
      </div>
    )}
  </main>

  <Footer locale="fr" />
</Layout>

<style>
  .blog-index {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--space-24) var(--space-8) var(--space-20);
  }

  .blog-header {
    margin-bottom: var(--space-12);
  }

  .blog-header h1 {
    font-size: var(--text-h1);
    margin-bottom: var(--space-3);
  }

  .blog-header p {
    font-size: var(--text-lg);
    color: var(--color-gray);
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-16);
    transition: box-shadow var(--duration-base), transform var(--duration-base);
    background: var(--color-white);
  }

  .featured-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(calc(var(--space-1) * -0.75));
  }

  .featured-card img {
    width: var(--size-full);
    height: var(--size-full);
    object-fit: cover;
    display: block;
    min-height: calc(var(--space-20) * 3.5);
  }

  .featured-body {
    padding: var(--space-10) var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }

  .featured-eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .featured-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    padding: calc(var(--space-1) * 0.8) calc(var(--space-3) * 0.8);
    border-radius: var(--radius-pill);
  }

  .featured-body h2 {
    font-size: var(--text-h3);
    line-height: var(--leading-snug);
  }

  .featured-body p {
    color: var(--color-gray);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
  }

  .tag {
    background: var(--color-light-gray);
    color: var(--color-gray);
    padding: calc(var(--space-1) * 0.8) calc(var(--space-3) * 0.9);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .section-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading-tight);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: thin solid var(--color-border-light);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(calc(var(--space-20) * 3.75), 1fr));
    gap: calc(var(--space-8) - var(--space-1));
  }

  .post-card {
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--duration-base), transform var(--duration-base);
    background: var(--color-white);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(calc(var(--space-1) * -0.75));
  }

  .post-card img {
    width: var(--size-full);
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .post-card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }

  .post-card-body h3 {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }

  .post-card-body p {
    color: var(--color-gray);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .empty-state {
    text-align: center;
    color: var(--color-gray);
    padding: var(--space-12) 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-4);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
    padding: var(--button-padding-y) var(--space-8);
    border-radius: var(--button-radius);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
  }
</style>
