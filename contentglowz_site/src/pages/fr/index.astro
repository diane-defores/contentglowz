---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Problem from '../../components/Problem.astro';
import Robots from '../../components/Robots.astro';
import Features from '../../components/Features.astro';
import Testimonials from '../../components/Testimonials.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import ClosingCta from '../../components/ClosingCta.astro';
import Footer from '../../components/Footer.astro';
import { homepageContent } from '../../data/homepageContent';

const content = homepageContent.fr;
---

<Layout
  title={content.title}
  description={content.description}
  locale="fr"
  canonicalUrl="https://contentglowz.com/fr/"
  alternateLocales={[
    { locale: 'en', href: 'https://contentglowz.com/' },
    { locale: 'fr', href: 'https://contentglowz.com/fr/' },
  ]}
>
  <Navbar locale="fr" />
  <main class="landing-shell">
    <Hero content={content.hero} />
    <Problem content={content.problem} />
    <Robots content={content.robots} />
    <Features content={content.features} />
    <Testimonials content={content.testimonials} />
    <Pricing content={content.pricing} />
    <FAQ content={content.faq} />
    <ClosingCta content={content.closingCta} />
  </main>
  <Footer locale="fr" />
</Layout>

<style>
  .landing-shell > section + section {
    position: relative;
  }

  .landing-shell > section + section::before {
    content: "";
    position: absolute;
    inset-inline: var(--space-8);
    inset-block-start: calc(var(--space-1) * -1);
    inline-size: calc(100% - (var(--space-8) * 2));
    block-size: calc(var(--space-1) / 4);
    background: color-mix(in srgb, var(--color-surface) 82%, transparent);
    box-shadow: var(--shadow-card);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .landing-shell > section + section::before {
      inset-inline: var(--space-4);
      inline-size: calc(100% - (var(--space-4) * 2));
    }
  }
</style>
