---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — ContentGlowz" description="The page you're looking for doesn't exist." noindex={true}>
  <Navbar />
  <main id="main-content" class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <a href="/" class="back-home">Back to Home</a>
  </main>
  <Footer />
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: var(--height-screen-half);
    text-align: center;
    padding: calc(var(--space-16) * 2) var(--space-8) var(--space-16);
  }

  .not-found h1 {
    font-size: calc(var(--text-h1) * var(--leading-readable));
    font-weight: 900;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  .not-found p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .back-home {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
        padding: var(--button-padding-y) var(--space-8);
    border-radius: var(--button-radius);
    font-weight: 600;
    transition: transform var(--duration-base), box-shadow var(--duration-base);
  }

  .back-home:hover {
    transform: translateY(var(--motion-lift-sm));
    box-shadow: var(--shadow-primary);
  }
</style>
