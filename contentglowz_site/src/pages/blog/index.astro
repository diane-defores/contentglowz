---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts.find((p) => p.data.featured);
const rest = posts.filter((p) => p.id !== featured?.id);
---

<Layout
  title="Blog — ContentGlowz"
  description="Guides, case studies, and technical deep-dives on AI automation for SEO, newsletters, and content generation."
  ogType="website"
>
  <Navbar />

  <main id="main-content" class="blog-index">
    <div class="blog-header">
      <h1>Blog</h1>
      <p>Guides, case studies, and technical deep-dives on AI automation.</p>
    </div>

    <!-- Featured post -->
    {featured && (
      <a href={`/blog/${featured.id}`} class="featured-card">
        {featured.data.cover && (
          <img src={featured.data.cover} alt={`Featured: ${featured.data.title}`} width="800" height="420" />
        )}
        <div class="featured-body">
          <div class="featured-eyebrow">
            {featured.data.tags?.slice(0, 2).map((t) => (
              <span class="tag">{t}</span>
            ))}
            <span class="featured-badge">Featured</span>
          </div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="post-meta">
            <span>{featured.data.byline}</span>
            <span>·</span>
            <time datetime={featured.data.date.toISOString()}>
              {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </div>
      </a>
    )}

    <!-- Post grid -->
    {rest.length > 0 && (
      <section class="posts-section">
        <h2 class="section-title">All articles</h2>
        <div class="posts-grid">
          {rest.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card">
              {post.data.cover && (
                <img src={post.data.cover} alt={`Illustration for ${post.data.title}`} width="400" height="210" />
              )}
              <div class="post-card-body">
                {post.data.tags?.slice(0, 2).map((t) => (
                  <span class="tag">{t}</span>
                ))}
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="empty-state">
        <p>No articles yet — check back soon.</p>
        <a href="/" class="btn">Back to home</a>
      </div>
    )}
  </main>

  <Footer />
</Layout>

<style>
  .blog-index {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--space-24) var(--space-8); var(--space-20);
  }

  .blog-header {
    margin-bottom: var(--space-12);
  }

  .blog-header h1 {
    font-size: var(--text-h1);
    margin-bottom: var(--space-3);
  }

  .blog-header p {
    font-size: var(--text-lg);
    color: var(--color-gray);
  }

  /* Featured card */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-16);
    transition: box-shadow var(--duration-base), transform var(--duration-base);
    background: var(--color-white);
  }

  .featured-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(calc(var(--space-1) * -0.75));
  }

  .featured-card img {
    width: var(--size-full);
    height: var(--size-full);
    object-fit: cover;
    display: block;
    min-height: calc(var(--space-20) * 3.5);
  }

  .featured-body {
    padding: var(--space-10); var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }

  .featured-eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .featured-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    padding: calc(var(--space-1) * 0.8) calc(var(--space-3) * 0.8);
    border-radius: var(--radius-pill);
  }

  .featured-body h2 {
    font-size: var(--text-h3);
    line-height: var(--leading-snug);
  }

  .featured-body p {
    color: var(--color-gray);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
  }

  /* Tags */
  .tag {
    background: var(--color-light-gray);
    color: var(--color-gray);
    padding: calc(var(--space-1) * 0.8) calc(var(--space-3) * 0.9);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  /* Posts grid */
  .section-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading-tight);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: thin solid var(--color-border-light);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(calc(var(--space-20) * 3.75), 1fr));
    gap: calc(var(--space-8) - var(--space-1));
  }

  .post-card {
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--duration-base), transform var(--duration-base);
    background: var(--color-white);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(calc(var(--space-1) * -0.5));
  }

  .post-card img {
    width: var(--size-full);
    height: calc(var(--space-20) * 2.5);
    object-fit: cover;
    display: block;
  }

  .post-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .post-card-body h3 {
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    margin-top: var(--space-1);
  }

  .post-card-body p {
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: var(--leading-copy);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: var(--space-20); var(--space-8);
    color: var(--color-gray);
  }

  .btn {
    display: inline-block;
    margin-top: var(--space-5);
    background: var(--color-primary);
    color: var(--color-white);
    padding: var(--button-padding-y); var(--space-8);
    border-radius: var(--radius-sm);
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: var(--breakpoint-compact-max)) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-card img {
      min-height: calc(var(--space-20) * 2.75);
    }
  }
</style>
