---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Map<string, string>();

  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => {
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      if (!tags.has(slug)) tags.set(slug, tag);
    });
  });

  return Array.from(tags.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: posts
        .filter((p) => p.data.tags?.some((t) => t.toLowerCase().replace(/\s+/g, '-') === slug))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { label, posts } = Astro.props;
---

<Layout
  title={`${label} — ContentGlowz Blog`}
  description={`Articles tagged "${label}" on the ContentGlowz blog.`}
>
  <Navbar />

  <header class="tag-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <a href="/blog">Blog</a>
      <span>›</span>
      <span>{label}</span>
    </nav>
  </header>

  <main id="main-content" class="tag-main">
    <h1>Tag: {label}</h1>
    <p class="count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>

    <div class="posts-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          {post.data.cover && (
            <img src={post.data.cover} alt={`Illustration for ${post.data.title}`} width="400" height="210" />
          )}
          <div class="post-card-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>

    <a href="/blog" class="back-link">← Back to Blog</a>
  </main>

  <Footer />
</Layout>

<style>
  .tag-header {
        padding: var(--space-20) var(--space-8) var(--space-6);
    border-bottom: thin solid var(--color-border-light);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
    max-width: calc(var(--container-max-width) - var(--space-20) * 2.5);
    margin: 0 auto;
  }

  .breadcrumb a:hover { color: var(--color-primary); }

  .tag-main {
    max-width: calc(var(--container-max-width) - var(--space-20) * 2.5);
    margin: 0 auto;
        padding: var(--space-8) var(--space-8) var(--space-16);
  }

  .tag-main h1 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-1);
  }

  .count {
    color: var(--color-gray);
    margin-bottom: var(--space-8);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .post-card {
    display: flex;
    gap: var(--space-6);
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--duration-base), transform var(--duration-base);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(calc(var(--space-1) * -0.5));
  }

  .post-card img {
    width: calc(var(--space-20) * 2.5);
    height: calc((var(--space-16) * 2) + var(--space-3));
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-card-body {
        padding: var(--space-5) var(--space-5) var(--space-5) var(--space-0);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post-card-body h2 {
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .post-card-body p {
    font-size: var(--text-sm);
    color: var(--color-gray);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-body time {
    font-size: var(--text-xs);
    color: var(--color-gray);
    margin-top: auto;
  }

  .back-link {
    color: var(--color-gray);
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }

  .back-link:hover { color: var(--color-primary); }

  @media (max-width: var(--breakpoint-narrow-max)) {
    .post-card {
      flex-direction: column;
    }

    .post-card img {
      width: var(--size-full);
      height: calc(var(--space-20) + var(--space-24) + var(--space-4));
    }

    .post-card-body {
      padding: var(--space-4);
    }
  }
</style>
