---
import Layout from '../layouts/Layout.astro';
import { appEntryUrl, appSignInUrl } from '../config/site';
---

<Layout
  title="Opening ContentGlowz App"
  description="Redirecting to the ContentGlowz app."
  noindex={true}
>
  <section class="redirect-shell">
    <div class="redirect-card">
      <p class="eyebrow">Open app</p>
      <h1>Opening the app entry…</h1>
      <p>
        The old website handoff has been retired. ContentGlowz now opens the app
        directly on the app domain, where sign-in and session restore both happen.
      </p>
      <div class="actions">
        <a class="btn-primary" href={appEntryUrl}>Open app entry</a>
        <a class="btn-secondary" href={appSignInUrl}>Go to sign-in</a>
      </div>
    </div>
  </section>

  <script define:vars={{ appEntryUrl }}>
    window.location.replace(appEntryUrl);
  </script>
</Layout>

<style>
  .redirect-shell {
    min-height: var(--height-screen);
    display: grid;
    place-items: center;
    padding: var(--space-8);
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--color-secondary) 12%, transparent), transparent 45%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-secondary) 4%, var(--color-surface)) 0%, color-mix(in srgb, var(--color-secondary) 8%, var(--color-surface)) 100%);
  }

  .redirect-card {
    width: min(100%, calc(var(--space-20) * 7));
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--color-surface-card-glass);
    border: calc(var(--space-1) / 4) solid var(--color-border-light);
    box-shadow: var(--shadow-card-lg);
    text-align: center;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: var(--space-3);
  }

  h1 {
    font-size: var(--text-h1);
    margin-bottom: var(--space-4);
  }

  p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
