---
import Layout from '../layouts/Layout.astro';

const clerkPublishableKey = import.meta.env.CLERK_PUBLISHABLE_KEY ?? '';
const appWebUrl = import.meta.env.APP_WEB_URL ?? 'https://contentflow.winflowz.com';
---

<Layout
  title="Sign In — ContentFlow"
  description="Sign in to ContentFlow on the website, then continue into the app."
  noindex={true}
>
  <section class="auth-shell">
    <div class="auth-copy">
      <p class="eyebrow">Website login</p>
      <h1>Sign in before opening the app.</h1>
      <p>
        ContentFlow web login runs here so Google sign-in and browser password managers
        use a normal web flow before sending you back to the Flutter app.
      </p>
      <div class="auth-links">
        <a class="btn-secondary" href="/sign-up">Create account</a>
        <a class="btn-secondary" href="/launch">Already signed in? Open app</a>
      </div>
    </div>
    <div class="auth-panel">
      <div id="auth-status" class="auth-status">Loading secure sign-in…</div>
      <button id="copy-auth-error" class="copy-error-button" type="button" hidden>
        Copy error
      </button>
      <div id="clerk-auth"></div>
    </div>
  </section>

  <script
    id="clerk-browser-script"
    defer
    crossorigin="anonymous"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
  ></script>
  <script define:vars={{ clerkPublishableKey, appWebUrl }}>
    const statusEl = document.getElementById('auth-status');
    const mountNode = document.getElementById('clerk-auth');
    const copyButton = document.getElementById('copy-auth-error');
    const clerkScript = document.getElementById('clerk-browser-script');
    const redirectTarget =
      new URLSearchParams(window.location.search).get('redirect_url') ||
      `${appWebUrl}/entry`;
    const continueUrl = `/launch?redirect_url=${encodeURIComponent(redirectTarget)}`;
    let lastErrorText = '';

    async function copyError() {
      if (!lastErrorText) {
        return;
      }

      try {
        await navigator.clipboard.writeText(lastErrorText);
        copyButton.textContent = 'Copied';
        window.setTimeout(() => {
          copyButton.textContent = 'Copy error';
        }, 1500);
      } catch (_) {
        copyButton.textContent = 'Copy failed';
      }
    }

    function showError(message) {
      lastErrorText = [
        message,
        `Host: ${window.location.host}`,
        `Path: ${window.location.pathname}`,
        `Key preview: ${clerkPublishableKey ? `${clerkPublishableKey.slice(0, 12)}...${clerkPublishableKey.slice(-5)}` : 'missing'}`,
      ].join('\n');
      statusEl.textContent = message;
      copyButton.hidden = false;
    }

    copyButton.addEventListener('click', copyError);
    clerkScript?.addEventListener('error', () => {
      showError('Clerk CDN script failed to load in the browser.');
    });

    async function bootSignIn() {
      if (!clerkPublishableKey) {
        showError('CLERK_PUBLISHABLE_KEY is missing on the website deployment.');
        return;
      }

      if (!window.Clerk) {
        showError('Clerk failed to load in the browser.');
        return;
      }

      try {
        await window.Clerk.load({ publishableKey: clerkPublishableKey });
        if (window.Clerk.session) {
          window.location.replace(continueUrl);
          return;
        }

        statusEl.textContent = 'Use your ContentFlow account to continue.';
        window.Clerk.mountSignIn(mountNode, {
          signUpUrl: `/sign-up?redirect_url=${encodeURIComponent(redirectTarget)}`,
        });

        const sync = window.setInterval(() => {
          if (window.Clerk?.session) {
            window.clearInterval(sync);
            window.location.replace(continueUrl);
          }
        }, 800);
      } catch (error) {
        showError(
          error instanceof Error ? error.message : 'Unable to render Clerk sign-in.',
        );
      }
    }

    window.addEventListener('load', bootSignIn);
  </script>
</Layout>

<style>
  .auth-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 460px);
    gap: 2rem;
    align-items: center;
    padding: 7rem 2rem 3rem;
    max-width: 1180px;
    margin: 0 auto;
  }

  .auth-copy h1 {
    font-size: clamp(2.2rem, 1.2rem + 3vw, 4rem);
    margin-bottom: 1rem;
  }

  .auth-copy p {
    color: var(--color-gray);
    font-size: 1.05rem;
    max-width: 44rem;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }

  .auth-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .auth-panel {
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.08);
  }

  .auth-status {
    margin-bottom: 1rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .copy-error-button {
    margin-bottom: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.14);
    background: rgba(15, 23, 42, 0.04);
    color: var(--color-dark);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font: inherit;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .auth-shell {
      grid-template-columns: 1fr;
      padding-top: 6rem;
    }
  }
</style>
