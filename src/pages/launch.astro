---
import Layout from '../layouts/Layout.astro';

const clerkPublishableKey = import.meta.env.CLERK_PUBLISHABLE_KEY ?? '';
const apiBaseUrl = import.meta.env.API_BASE_URL ?? 'https://api.winflowz.com';
const appWebUrl = import.meta.env.APP_WEB_URL ?? 'https://app.contentflow.winflowz.com';

function getClerkFrontendApi(publishableKey: string) {
  const encoded = publishableKey.split('_')[2];
  if (!encoded) {
    return '';
  }

  try {
    const normalized = encoded.replace(/-/g, '+').replace(/_/g, '/');
    const padded = normalized.padEnd(
      normalized.length + ((4 - (normalized.length % 4)) % 4),
      '=',
    );
    return Buffer.from(padded, 'base64').toString('utf-8').replace(/\$$/, '');
  } catch {
    return '';
  }
}

const clerkFrontendApi = getClerkFrontendApi(clerkPublishableKey);
const clerkScriptSrc = clerkFrontendApi
  ? `https://${clerkFrontendApi}/npm/@clerk/clerk-js@5/dist/clerk.browser.js`
  : '';
---

<Layout
  title="Opening App — ContentFlow"
  description="Exchanging your website session for an app session."
  noindex={true}
>
  <section class="launch-shell">
    <div class="launch-card">
      <p class="eyebrow">App handoff</p>
      <h1>Opening your workspace…</h1>
      <p id="launch-status">
        ContentFlow is turning your website login into a short-lived app handoff.
      </p>
      <button id="copy-launch-error" class="copy-error-button" type="button" hidden>
        Copy error
      </button>
      <div class="launch-actions">
        <a class="btn-secondary" href="/sign-in">Back to sign in</a>
        <a class="btn-secondary" href={appWebUrl}>Open app home</a>
      </div>
    </div>
  </section>

  {clerkScriptSrc && (
    <script
      id="clerk-browser-script"
      async
      crossorigin="anonymous"
      data-clerk-publishable-key={clerkPublishableKey}
      src={clerkScriptSrc}
      type="text/javascript"
    ></script>
  )}
  <script define:vars={{ clerkPublishableKey, apiBaseUrl, appWebUrl }}>
    const statusEl = document.getElementById('launch-status');
    const copyButton = document.getElementById('copy-launch-error');
    const clerkScript = document.getElementById('clerk-browser-script');
    let lastErrorText = '';

    async function copyError() {
      if (!lastErrorText) {
        return;
      }

      try {
        await navigator.clipboard.writeText(lastErrorText);
        copyButton.textContent = 'Copied';
        window.setTimeout(() => {
          copyButton.textContent = 'Copy error';
        }, 1500);
      } catch (_) {
        copyButton.textContent = 'Copy failed';
      }
    }

    function showError(message) {
      lastErrorText = [
        message,
        `Host: ${window.location.host}`,
        `Path: ${window.location.pathname}`,
        `API base: ${apiBaseUrl}`,
        `Clerk frontend API: ${clerkFrontendApi || 'missing'}`,
        `Key preview: ${clerkPublishableKey ? `${clerkPublishableKey.slice(0, 12)}...${clerkPublishableKey.slice(-5)}` : 'missing'}`,
      ].join('\n');
      statusEl.textContent = message;
      copyButton.hidden = false;
    }

    copyButton.addEventListener('click', copyError);
    clerkScript?.addEventListener('error', () => {
      showError('Clerk CDN script failed to load in the browser.');
    });

    async function launchApp() {
      const redirectTarget =
        new URLSearchParams(window.location.search).get('redirect_url') ||
        `${appWebUrl}/entry`;

      if (!clerkPublishableKey) {
        showError('CLERK_PUBLISHABLE_KEY is missing on the website deployment.');
        return;
      }

      if (!window.Clerk) {
        showError('Clerk failed to load in the browser.');
        return;
      }

      try {
        await window.Clerk.load({ publishableKey: clerkPublishableKey });
        if (!window.Clerk.session) {
          window.location.replace(
            `/sign-in?redirect_url=${encodeURIComponent(redirectTarget)}`,
          );
          return;
        }

        statusEl.textContent = 'Requesting a secure app handoff…';
        const bearerToken = await window.Clerk.session.getToken();
        if (!bearerToken) {
          throw new Error('Clerk did not return a session token for the app handoff.');
        }

        const response = await fetch(`${apiBaseUrl}/api/auth/web/handoff`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${bearerToken}`,
          },
        });

        if (!response.ok) {
          const body = await response.json().catch(() => ({}));
          throw new Error(
            body?.detail || 'The backend rejected the website handoff request.',
          );
        }

        const payload = await response.json();
        const handoffToken = payload?.handoff_token;
        if (!handoffToken) {
          throw new Error('The backend did not return a handoff token.');
        }

        const appUrl = new URL(redirectTarget, window.location.origin);
        appUrl.searchParams.set('handoff_token', handoffToken);
        statusEl.textContent = 'Redirecting to the app…';
        window.location.replace(appUrl.toString());
      } catch (error) {
        showError(error instanceof Error ? error.message : 'Unable to open the app.');
      }
    }

    window.addEventListener('load', launchApp);
  </script>
</Layout>

<style>
  .launch-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 7rem 2rem 3rem;
  }

  .launch-card {
    width: min(100%, 720px);
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.08);
  }

  .launch-card h1 {
    font-size: clamp(2rem, 1.2rem + 2vw, 3rem);
    margin-bottom: 1rem;
  }

  .launch-card p {
    color: var(--color-gray);
    font-size: 1rem;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }

  .launch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .copy-error-button {
    margin-top: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.14);
    background: rgba(15, 23, 42, 0.04);
    color: var(--color-dark);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font: inherit;
    cursor: pointer;
  }
</style>
