---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts.find((p) => p.data.featured);
const rest = posts.filter((p) => p.slug !== featured?.slug);
---

<Layout
  title="Blog — ContentFlow"
  description="Guides, case studies, and technical deep-dives on AI automation for SEO, newsletters, and content generation."
  ogType="website"
>
  <!-- Minimal nav -->
  <header class="blog-nav">
    <a href="/" class="logo">ContentFlow</a>
    <nav>
      <a href="/">Home</a>
      <a href="/blog" class="active">Blog</a>
    </nav>
  </header>

  <main class="blog-index">
    <div class="blog-header">
      <h1>Blog</h1>
      <p>Guides, case studies, and technical deep-dives on AI automation.</p>
    </div>

    <!-- Featured post -->
    {featured && (
      <a href={`/blog/${featured.slug}`} class="featured-card">
        {featured.data.cover && (
          <img src={featured.data.cover} alt={`Featured: ${featured.data.title}`} width="800" height="420" />
        )}
        <div class="featured-body">
          <div class="featured-eyebrow">
            {featured.data.tags?.slice(0, 2).map((t) => (
              <span class="tag">{t}</span>
            ))}
            <span class="featured-badge">Featured</span>
          </div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="post-meta">
            <span>{featured.data.byline}</span>
            <span>·</span>
            <time datetime={featured.data.date.toISOString()}>
              {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </div>
      </a>
    )}

    <!-- Post grid -->
    {rest.length > 0 && (
      <section class="posts-section">
        <h2 class="section-title">All articles</h2>
        <div class="posts-grid">
          {rest.map((post) => (
            <a href={`/blog/${post.slug}`} class="post-card">
              {post.data.cover && (
                <img src={post.data.cover} alt={`Illustration for ${post.data.title}`} width="400" height="210" />
              )}
              <div class="post-card-body">
                {post.data.tags?.slice(0, 2).map((t) => (
                  <span class="tag">{t}</span>
                ))}
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="empty-state">
        <p>No articles yet — check back soon.</p>
        <a href="/" class="btn">Back to home</a>
      </div>
    )}
  </main>

  <footer class="blog-footer">
    <p>© {new Date().getFullYear()} ContentFlow · <a href="/">Home</a></p>
  </footer>
</Layout>

<style>
  .blog-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--color-light-gray);
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  .logo { font-weight: 800; font-size: 1.1rem; color: var(--color-dark); }

  .blog-nav nav { display: flex; gap: 1.5rem; }
  .blog-nav nav a { font-size: 0.9rem; color: var(--color-gray); }
  .blog-nav nav a.active { color: var(--color-primary); font-weight: 600; }
  .blog-nav nav a:hover { color: var(--color-primary); }

  .blog-index {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .blog-header p {
    font-size: 1.125rem;
    color: var(--color-gray);
  }

  /* Featured card */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    border: 1px solid var(--color-light-gray);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 4rem;
    transition: box-shadow 0.2s, transform 0.2s;
    background: var(--color-white);
  }

  .featured-card:hover {
    box-shadow: 0 12px 32px rgba(0,0,0,0.09);
    transform: translateY(-3px);
  }

  .featured-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 280px;
  }

  .featured-body {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .featured-eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .featured-badge {
    background: #fef3c7;
    color: #92400e;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .featured-body h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    line-height: 1.3;
  }

  .featured-body p {
    color: var(--color-gray);
    font-size: 1rem;
    line-height: 1.6;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.825rem;
    color: var(--color-gray);
  }

  /* Tags */
  .tag {
    background: var(--color-light-gray);
    color: var(--color-gray);
    padding: 0.2rem 0.7rem;
    border-radius: 99px;
    font-size: 0.72rem;
    font-weight: 500;
  }

  /* Posts grid */
  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-light-gray);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .post-card {
    border: 1px solid var(--color-light-gray);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
    background: var(--color-white);
  }

  .post-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .post-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .post-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .post-card-body h3 {
    font-size: 1.05rem;
    line-height: 1.4;
    margin-top: 0.25rem;
  }

  .post-card-body p {
    font-size: 0.875rem;
    color: var(--color-gray);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 5rem 2rem;
    color: var(--color-gray);
  }

  .btn {
    display: inline-block;
    margin-top: 1.25rem;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-weight: 600;
  }

  .blog-footer {
    text-align: center;
    padding: 2rem;
    border-top: 1px solid var(--color-light-gray);
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  .blog-footer a { color: var(--color-primary); }

  /* Responsive */
  @media (max-width: 700px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-card img {
      min-height: 220px;
    }
  }
</style>
