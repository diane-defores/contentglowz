---
import Layout from '../layouts/Layout.astro';
import { appSignInUrl } from '../config/site';
---

<Layout
  title="Redirecting to App Sign-In — ContentFlow"
  description="Redirecting to the official ContentFlow app sign-in flow."
  noindex={true}
>
  <section class="redirect-shell">
    <div class="redirect-card">
      <p class="eyebrow">Account access</p>
      <h1>Account creation moved to the app domain.</h1>
      <p>
        ContentFlow no longer creates accounts on the marketing site. The official
        Clerk Google flow now lives directly on the app.
      </p>
      <a class="btn-primary" href={appSignInUrl}>Continue with Google</a>
    </div>
  </section>

  <script define:vars={{ appSignInUrl }}>
    const target = new URL(appSignInUrl);
    const params = new URLSearchParams(window.location.search);
    const redirectUrl = params.get('redirect_url');
    if (redirectUrl) {
      target.searchParams.set('redirect_url', redirectUrl);
    }
    window.location.replace(target.toString());
  </script>
</Layout>

<style>
  .redirect-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(circle at top, rgba(6, 182, 212, 0.14), transparent 48%),
      linear-gradient(180deg, #f7fbfd 0%, #eef6fb 100%);
  }

  .redirect-card {
    width: min(100%, 540px);
    padding: 2rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2rem, 1.4rem + 2vw, 2.8rem);
    margin-bottom: 1rem;
  }

  p {
    color: var(--color-gray);
    margin-bottom: 1.5rem;
  }
</style>
