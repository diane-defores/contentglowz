---
import Layout from '../layouts/Layout.astro';
import {
  appWebUrl,
  buildCommitSha,
  buildEnvironment,
  buildTimestamp,
  siteUrl,
} from '../config/site';

const clerkPublishableKey = import.meta.env.CLERK_PUBLISHABLE_KEY ?? '';

function getClerkFrontendApi(publishableKey: string) {
  const encoded = publishableKey.split('_')[2];
  if (!encoded) {
    return '';
  }

  try {
    const normalized = encoded.replace(/-/g, '+').replace(/_/g, '/');
    const padded = normalized.padEnd(
      normalized.length + ((4 - (normalized.length % 4)) % 4),
      '=',
    );
    return Buffer.from(padded, 'base64').toString('utf-8').replace(/\$$/, '');
  } catch {
    return '';
  }
}

const clerkFrontendApi = getClerkFrontendApi(clerkPublishableKey);
const clerkScriptSrc = clerkFrontendApi
  ? `https://${clerkFrontendApi}/npm/@clerk/clerk-js@5/dist/clerk.browser.js`
  : '';
---

<Layout
  title="Create Account — ContentFlow"
  description="Create your ContentFlow account on the website, then continue into the app."
  noindex={true}
>
  <section class="auth-shell">
    <div class="auth-copy">
      <p class="eyebrow">Website signup</p>
      <h1>Create your workspace account.</h1>
      <p>
        Start on the website with the official Clerk web flow, then continue into
        the ContentFlow app with a secure short-lived handoff.
      </p>
      <div class="auth-links">
        <a class="btn-secondary" href="/sign-in">Already have an account?</a>
        <a class="btn-secondary" href="/launch">Already signed in? Open app</a>
      </div>
    </div>
    <div class="auth-panel">
      <div id="auth-status" class="auth-status">Loading account creation…</div>
      <button id="copy-auth-error" class="copy-error-button" type="button" hidden>
        Copy diagnostics
      </button>
      <details id="auth-diagnostics" class="auth-diagnostics" hidden>
        <summary>Technical diagnostics</summary>
        <pre id="auth-diagnostics-body"></pre>
      </details>
      <div id="clerk-auth"></div>
    </div>
  </section>

  {clerkScriptSrc && (
    <script
      id="clerk-browser-script"
      async
      crossorigin="anonymous"
      data-clerk-publishable-key={clerkPublishableKey}
      src={clerkScriptSrc}
      type="text/javascript"
    ></script>
  )}
  <script
    define:vars={{
      appWebUrl,
      buildCommitSha,
      buildEnvironment,
      buildTimestamp,
      clerkPublishableKey,
      siteUrl,
    }}
  >
    const statusEl = document.getElementById('auth-status');
    const mountNode = document.getElementById('clerk-auth');
    const copyButton = document.getElementById('copy-auth-error');
    const diagnosticsEl = document.getElementById('auth-diagnostics');
    const diagnosticsBodyEl = document.getElementById('auth-diagnostics-body');
    const clerkScript = document.getElementById('clerk-browser-script');
    const searchParams = new URLSearchParams(window.location.search);
    const redirectTarget =
      searchParams.get('redirect_url') || `${appWebUrl}/#/entry`;
    const continueUrl = `/launch?redirect_url=${encodeURIComponent(redirectTarget)}`;
    const diagnosticsRequested = ['1', 'true', 'yes'].includes(
      (searchParams.get('diag') || '').toLowerCase(),
    );
    let lastErrorText = '';

    function configuredHost(url) {
      try {
        return new URL(url).host;
      } catch (_) {
        return 'invalid';
      }
    }

    function hostMatchLabel(url) {
      const host = configuredHost(url);
      if (host === 'invalid') {
        return `invalid (${url})`;
      }
      return host === window.location.host ? 'yes' : `no (expected ${host})`;
    }

    function buildDiagnostics(extraLines = []) {
      const queryKeys = [...searchParams.keys()];
      return [
        'ContentFlow website sign-up diagnostics',
        `Build commit: ${buildCommitSha}`,
        `Build environment: ${buildEnvironment}`,
        `Build timestamp: ${buildTimestamp}`,
        `Current URL: ${window.location.href}`,
        `Current origin: ${window.location.origin}`,
        `Current host: ${window.location.host}`,
        `Current path: ${window.location.pathname}`,
        `Referrer: ${document.referrer || 'none'}`,
        `Online: ${navigator.onLine ? 'yes' : 'no'}`,
        `Cookies enabled: ${navigator.cookieEnabled ? 'yes' : 'no'}`,
        `Timezone: ${Intl.DateTimeFormat().resolvedOptions().timeZone || 'unknown'}`,
        `User agent: ${navigator.userAgent}`,
        `Query keys: ${queryKeys.length > 0 ? queryKeys.join(', ') : 'none'}`,
        `redirect_url: ${searchParams.get('redirect_url') || 'missing'}`,
        `Redirect target: ${redirectTarget}`,
        `Configured APP_SITE_URL: ${siteUrl}`,
        `Configured APP_SITE_URL host match: ${hostMatchLabel(siteUrl)}`,
        `Configured APP_WEB_URL: ${appWebUrl}`,
        `Configured APP_WEB_URL host: ${configuredHost(appWebUrl)}`,
        `Continue URL: ${continueUrl}`,
        `Clerk script src: ${clerkScript?.getAttribute('src') || 'missing'}`,
        `Clerk frontend API: ${clerkFrontendApi || 'missing'}`,
        `Clerk global present: ${window.Clerk ? 'yes' : 'no'}`,
        `Clerk session present: ${window.Clerk?.session ? 'yes' : 'no'}`,
        `Key preview: ${clerkPublishableKey ? `${clerkPublishableKey.slice(0, 12)}...${clerkPublishableKey.slice(-5)}` : 'missing'}`,
        ...extraLines,
      ].join('\n');
    }

    function renderDiagnostics(extraLines = [], forceVisible = diagnosticsRequested) {
      const text = buildDiagnostics(extraLines);
      diagnosticsBodyEl.textContent = text;
      diagnosticsEl.hidden = !forceVisible;
      if (forceVisible) {
        diagnosticsEl.open = true;
      }
      copyButton.hidden = !(forceVisible || lastErrorText);
      return text;
    }

    function renderSignedInState() {
      const email =
        window.Clerk?.user?.primaryEmailAddress?.emailAddress ||
        window.Clerk?.user?.emailAddresses?.[0]?.emailAddress ||
        'your current account';
      statusEl.textContent = `Already signed in as ${email}. Open the app or sign out first to create another account.`;
      mountNode.innerHTML = `
        <div class="signed-in-actions">
          <a class="btn-secondary" href="${continueUrl}">Open app</a>
          <button class="btn-secondary signed-in-signout" type="button">Sign out</button>
        </div>
      `;
      const signOutButton = mountNode.querySelector('.signed-in-signout');
      signOutButton?.addEventListener('click', async () => {
        await window.Clerk.signOut();
        window.location.reload();
      });
      renderDiagnostics([
        'Status: Clerk session already exists',
        `Resolved email: ${email}`,
      ]);
    }

    async function copyError() {
      const diagnostics = lastErrorText || renderDiagnostics();
      if (!diagnostics) {
        return;
      }

      try {
        await navigator.clipboard.writeText(diagnostics);
        copyButton.textContent = 'Copied';
        window.setTimeout(() => {
          copyButton.textContent = 'Copy diagnostics';
        }, 1500);
      } catch (_) {
        copyButton.textContent = 'Copy failed';
      }
    }

    function showError(message) {
      lastErrorText = renderDiagnostics(
        [
          'Status: error',
          `Error: ${message}`,
        ],
        true,
      );
      statusEl.textContent = message;
    }

    copyButton.addEventListener('click', copyError);
    clerkScript?.addEventListener('error', () => {
      showError('Clerk CDN script failed to load in the browser.');
    });

    async function bootSignUp() {
      if (!clerkPublishableKey) {
        showError('CLERK_PUBLISHABLE_KEY is missing on the website deployment.');
        return;
      }

      if (!window.Clerk) {
        showError('Clerk failed to load in the browser.');
        return;
      }

      try {
        renderDiagnostics(['Status: Loading Clerk browser SDK']);
        await window.Clerk.load({ publishableKey: clerkPublishableKey });
        if (window.Clerk.session) {
          renderSignedInState();
          return;
        }

        statusEl.textContent = 'Create your account to continue.';
        renderDiagnostics([
          'Status: Mounting Clerk sign-up',
          'Clerk session present: no',
        ]);
        window.Clerk.mountSignUp(mountNode, {
          signInUrl: `/sign-in?redirect_url=${encodeURIComponent(redirectTarget)}`,
        });

        const sync = window.setInterval(() => {
          if (window.Clerk?.session) {
            window.clearInterval(sync);
            renderDiagnostics([
              'Status: Clerk session detected after mount',
              'Redirecting to launch page',
            ]);
            window.location.replace(continueUrl);
          }
        }, 800);
      } catch (error) {
        showError(
          error instanceof Error ? error.message : 'Unable to render Clerk sign-up.',
        );
      }
    }

    renderDiagnostics(['Status: Booting sign-up page']);
    window.addEventListener('load', bootSignUp);
  </script>
</Layout>

<style>
  .auth-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 460px);
    gap: 2rem;
    align-items: center;
    padding: 7rem 2rem 3rem;
    max-width: 1180px;
    margin: 0 auto;
  }

  .auth-copy h1 {
    font-size: clamp(2.2rem, 1.2rem + 3vw, 4rem);
    margin-bottom: 1rem;
  }

  .auth-copy p {
    color: var(--color-gray);
    font-size: 1.05rem;
    max-width: 44rem;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }

  .auth-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .auth-panel {
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 24px;
    padding: 1.5rem;
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.08);
  }

  .auth-status {
    margin-bottom: 1rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .copy-error-button {
    margin-bottom: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.14);
    background: rgba(15, 23, 42, 0.04);
    color: var(--color-dark);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font: inherit;
    cursor: pointer;
  }

  .auth-diagnostics {
    margin-bottom: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 16px;
    padding: 0.8rem 0.95rem;
    background: rgba(15, 23, 42, 0.03);
  }

  .auth-diagnostics summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-dark);
  }

  .auth-diagnostics pre {
    margin: 0.9rem 0 0;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-gray);
  }

  @media (max-width: 900px) {
    .auth-shell {
      grid-template-columns: 1fr;
      padding-top: 6rem;
    }
  }
</style>
