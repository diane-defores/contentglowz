---
const faqData = [
  { question: "Does the AI really sound like me?", answer: "Yes. The Psychology Engine learns your voice through weekly rituals and evolves with your narrative arc. It's not generic AI — it's trained on your specific positioning, tone, and audience personas." },
  { question: "What content formats are supported?", answer: "Blog articles, newsletters, social posts (Twitter/LinkedIn/Instagram), short-form video scripts (TikTok/Reels/Shorts), and YouTube video scripts. One idea generates all formats." },
  { question: "Where can I publish from ContentFlow?", answer: "Twitter/X, LinkedIn, Instagram, TikTok, YouTube, Ghost, and WordPress. Connect your accounts via OAuth in the Settings screen. More platforms coming soon." },
  { question: "Do I review every piece of content?", answer: "Yes, you're always in control. AI generates, you approve. The swipe feed makes review fast — most creators spend 5-10 minutes reviewing a day's worth of content." },
  { question: "How does SEO work?", answer: "ContentFlow uses DataForSEO for real keyword data, competitor analysis, and SERP tracking. Articles are optimized for keywords with real search volume. Your content ranks because it's data-driven, not guessed." },
  { question: "What about affiliate links?", answer: "Register your affiliate programs with keywords. AI automatically weaves relevant links into generated content when the topic matches. You control which programs are active." },
  { question: "Are API costs included?", answer: "Yes. All AI generation costs (LLM, search, analysis) are included in your plan. No surprise bills. The pricing is what you see." },
  { question: "Can I use it on mobile?", answer: "The Flutter app works on Android, iOS, and web. Review and approve content from anywhere. The swipe interface was designed mobile-first." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<section id="faq" class="faq-section">
  <div class="container">
    <div class="section-header">
      <h2>Frequently Asked Questions</h2>
      <p>Everything you need to know about ContentFlow</p>
    </div>

    <div class="faq-grid">
      {faqData.map(({ question, answer }, i) => (
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
            <span>{question}</span>
            <span class="icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id={`faq-answer-${i}`} role="region" aria-labelledby={`faq-q-${i}`}>
            <p>{answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 6rem 0;
    background: var(--color-light-gray);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 1.2rem + 3.33vw, 3rem);
    margin-bottom: 1rem;
    color: var(--color-dark);
  }

  .section-header p {
    font-size: 1.25rem;
    color: var(--color-gray);
  }

  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .faq-question {
    width: 100%;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-align: left;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .faq-question:hover {
    color: var(--color-primary);
  }

  .icon {
    font-size: 1.5rem;
    font-weight: 300;
    transition: transform 0.3s ease;
  }

  .faq-item.active .icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq-item.active .faq-answer {
    max-height: 500px;
    padding: 0 1.5rem 1.5rem;
  }

  .faq-answer p {
    color: var(--color-gray);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .faq-question {
      font-size: 1rem;
    }
  }
</style>

<script>
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    const question = item.querySelector('.faq-question');

    question?.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      // Close all items
      faqItems.forEach(i => {
        i.classList.remove('active');
        i.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });

      // Open clicked item if it wasn't active
      if (!isActive) {
        item.classList.add('active');
        question.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
