---
---

<a href="#main-content" class="skip-nav">Skip to content</a>
<nav class="navbar" aria-label="Main navigation">
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-icon">🤖</span>
      <span class="logo-text">ContentFlow</span>
    </a>
    <div class="nav-links" id="nav-links">
      <a href="/#features">Features</a>
      <a href="/#robots">Robots</a>
      <a href="/#pricing">Pricing</a>
      <a href="/#who-its-for">Who It's For</a>
      <a href="/#faq">FAQ</a>
      <a href="/blog">Blog</a>
      <a href="/launch">Open App</a>
    </div>
    <a
      href="/sign-up"
      class="cta-button"
      data-auth-cta
      data-signed-in-href="/launch"
      data-signed-in-label="Open App"
    >
      Create Account
    </a>
    <button class="hamburger" id="hamburger" aria-expanded="false" aria-controls="nav-links" aria-label="Toggle navigation menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<style>
  .skip-nav {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 1001;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0 0 8px 8px;
    font-weight: 600;
    transition: top 0.2s;
  }

  .skip-nav:focus {
    top: 0;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    padding: 1rem 0;
  }

  .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-dark);
  }

  .logo-icon {
    font-size: 2rem;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    color: var(--color-gray);
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .cta-button {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      padding: 1.5rem 2rem;
      gap: 1rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .nav-links.open {
      display: flex;
    }

    .hamburger {
      display: flex;
    }

    .cta-button {
      display: none;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    navLinks?.classList.toggle('open');
  });
</script>
