  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: white;
    padding: 4rem 0 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 1rem;
  }

  .logo-icon {
    font-size: 2rem;
  }

  .tagline {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: white;
    transition: all 0.3s ease;
  }

  .social-links a:hover {
    background: var(--color-primary);
    transform: translateY(-3px);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .link-column h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: white;
  }

  .link-column ul {
    list-style: none;
  }

  .link-column li {
    margin-bottom: 0.75rem;
  }

  .link-column a {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease;
  }

  .link-column a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
  }

  .footer-bottom-links {
    display: flex;
    gap: 2rem;
  }

  .footer-bottom-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .footer-bottom-links a:hover {
    color: white;
  }

  .opt-out-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .opt-out-btn:hover {
    color: white;
    border-color: rgba(255, 255, 255, 0.6);
  }

  .opt-out-btn.opted-out {
    border-color: rgba(76, 175, 80, 0.5);
    color: rgba(76, 175, 80, 0.8);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .footer-bottom-links {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  const btn = document.getElementById("analytics-opt-out");
  const label = document.getElementById("analytics-opt-out-label");

  function isOptedOut(): boolean {
    if (typeof window !== "undefined" && window.posthog?.has_opted_out_capturing) {
      return window.posthog.has_opted_out_capturing();
    }
    // Fallback: check for the cookie pattern PostHog uses
    return document.cookie.includes("ph_opt_in_out") && document.cookie.includes("0");
  }

  function updateLabel() {
    if (!label || !btn) return;
    if (isOptedOut()) {
      label.textContent = "Analytics disabled";
      btn.classList.add("opted-out");
    } else {
      label.textContent = "Disable analytics";
      btn.classList.remove("opted-out");
    }
  }

  btn?.addEventListener("click", () => {
    if (!window.posthog) {
      alert("PostHog is not loaded on this page.");
      return;
    }
    if (isOptedOut()) {
      window.posthog.opt_in_capturing();
    } else {
      window.posthog.opt_out_capturing();
    }
    updateLabel();
  });

  // Update on load
  updateLabel();
</script>
