---
import Layout from '../layouts/Layout.astro';
import { appEntryUrl, appSignInUrl } from '../config/site';
import { getHandoffCopy } from '../data/corePageCopy';
import { getCoreAlternates } from '../data/siteShell';

const copy = getHandoffCopy('launch', 'en');
---

<Layout
  title={copy.title}
  description={copy.description}
  locale="en"
  canonicalUrl="/launch"
  alternateLocales={getCoreAlternates('launch')}
  xDefaultUrl="/launch"
  noindex={true}
>
  <section class="redirect-shell">
    <div class="redirect-card">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.heading}</h1>
      <p>{copy.body}</p>
      <div class="actions">
        <a class="btn-primary" href={appEntryUrl}>{copy.primaryCta}</a>
        <a class="btn-secondary" href={appSignInUrl}>{copy.secondaryCta}</a>
      </div>
    </div>
  </section>

  <script define:vars={{ appEntryUrl }}>
    window.location.replace(appEntryUrl);
  </script>
</Layout>

<style>
  .redirect-shell {
    min-height: var(--height-screen);
    display: grid;
    place-items: center;
    padding: var(--space-8);
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--color-primary) 12%, transparent), transparent 45%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-primary) 4%, var(--color-surface)) 0%, color-mix(in srgb, var(--color-primary) 8%, var(--color-surface)) 100%);
  }

  .redirect-card {
    width: min(100%, calc(var(--space-20) * 7));
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--color-surface-card-glass);
    border: calc(var(--space-1) / 4) solid var(--color-border-light);
    box-shadow: var(--shadow-card-lg);
    text-align: center;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  h1 {
    font-size: var(--text-h1);
    margin-bottom: var(--space-4);
  }

  p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
