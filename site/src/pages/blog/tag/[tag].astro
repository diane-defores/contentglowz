---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import {
  filterBlogEntriesByLocale,
  formatBlogDate,
  getBlogBasePath,
  getBlogPostPath,
  getBlogLabels,
  getTagSlug,
} from '../../../data/blogContent';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const localizedPosts = filterBlogEntriesByLocale(posts, 'en');
  const tags = new Map<string, string>();

  localizedPosts.forEach((post) => {
    post.data.tags?.forEach((tag) => {
      const slug = getTagSlug(tag);
      if (!tags.has(slug)) tags.set(slug, tag);
    });
  });

  return Array.from(tags.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: localizedPosts
        .filter((p) => p.data.tags?.some((t) => getTagSlug(t) === slug))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { label, posts } = Astro.props;
const labels = getBlogLabels('en');
---

<Layout
  title={`${label} — ContentGlowz Blog`}
  description={labels.tagDescription(label)}
  locale="en"
  canonicalUrl={`/blog/tag/${getTagSlug(label)}`}
>
  <Navbar locale="en" />

  <header class="tag-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">{labels.home}</a>
      <span>›</span>
      <a href={getBlogBasePath('en')}>{labels.blogTitle}</a>
      <span>›</span>
      <span>{label}</span>
    </nav>
  </header>

  <main id="main-content" class="tag-main">
    <h1>{labels.tagTitle}: {label}</h1>
    <p class="count">{labels.articleCount(posts.length)}</p>

    <div class="posts-grid">
      {posts.map((post) => (
        <a href={getBlogPostPath(post, 'en')} class="post-card">
          {post.data.cover && (
            <img src={post.data.cover} alt={`Illustration for ${post.data.title}`} width="400" height="210" />
          )}
          <div class="post-card-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.date.toISOString()}>
              {formatBlogDate(post.data.date, 'en', 'long')}
            </time>
          </div>
        </a>
      ))}
    </div>

    <a href={getBlogBasePath('en')} class="back-link">← {labels.backToBlog}</a>
  </main>

  <Footer locale="en" />
</Layout>

<style>
  .tag-header {
        padding: var(--space-20) var(--space-8) var(--space-6);
    border-bottom: thin solid var(--color-border-light);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-gray);
    max-width: calc(var(--container-max-width) - var(--space-20) * 2.5);
    margin: 0 auto;
  }

  .breadcrumb a:hover { color: var(--color-primary); }

  .tag-main {
    max-width: calc(var(--container-max-width) - var(--space-20) * 2.5);
    margin: 0 auto;
        padding: var(--space-8) var(--space-8) var(--space-16);
  }

  .tag-main h1 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-1);
  }

  .count {
    color: var(--color-gray);
    margin-bottom: var(--space-8);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .post-card {
    display: flex;
    gap: var(--space-6);
    border: thin solid var(--color-border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--duration-base), transform var(--duration-base);
  }

  .post-card:hover {
    box-shadow: var(--shadow-card);
    transform: translateY(calc(var(--space-1) * -0.5));
  }

  .post-card img {
    width: calc(var(--space-20) * 2.5);
    height: calc((var(--space-16) * 2) + var(--space-3));
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-card-body {
        padding: var(--space-5) var(--space-5) var(--space-5) var(--space-0);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post-card-body h2 {
    font-size: var(--text-base);
    line-height: var(--leading-snug);
  }

  .post-card-body p {
    font-size: var(--text-sm);
    color: var(--color-gray);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-body time {
    font-size: var(--text-xs);
    color: var(--color-gray);
    margin-top: auto;
  }

  .back-link {
    color: var(--color-gray);
    font-size: var(--text-sm);
    transition: color var(--duration-fast);
  }

  .back-link:hover { color: var(--color-primary); }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }

    .post-card img {
      width: var(--size-full);
      height: calc(var(--space-20) + var(--space-24) + var(--space-4));
    }

    .post-card-body {
      padding: var(--space-4);
    }
  }
</style>
