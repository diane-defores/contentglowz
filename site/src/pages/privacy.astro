---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getPrivacyCopy } from '../data/corePageCopy';
import { getCoreAlternates } from '../data/siteShell';

const copy = getPrivacyCopy('en');
---

<Layout
  title={copy.title}
  description={copy.description}
  locale="en"
  canonicalUrl="/privacy"
  alternateLocales={getCoreAlternates('privacy')}
  xDefaultUrl="/privacy"
>
  <Navbar locale="en" />
  <main id="main-content" class="privacy-main">
    <h1>{copy.heading}</h1>
    <p class="last-updated">{copy.lastUpdated}</p>

    <div class="privacy-content">
      {copy.sections.map((section) => (
        <section>
          <h2>{section.heading}</h2>
          {section.paragraphs?.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
        </section>
      ))}
    </div>
  </main>
  <Footer locale="en" />
</Layout>

<style>
  .privacy-main {
    max-width: calc(var(--space-20) * 10);
    margin: 0 auto;
    padding: calc(var(--space-16) * 2) var(--space-8) var(--space-16);
  }

  .privacy-main h1 {
    font-size: var(--text-h1);
    font-weight: 800;
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
  }

  .last-updated {
    color: var(--color-text-muted);
    margin-bottom: var(--space-12);
    font-size: var(--text-sm);
  }

  .privacy-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .privacy-content h2 {
    font-size: var(--text-h3);
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .privacy-content p {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .privacy-content ul {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-6);
  }
</style>
