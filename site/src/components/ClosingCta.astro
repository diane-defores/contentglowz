---
import { appSignInUrl } from '../config/site';
import type { ClosingCtaContent } from '../data/homepageContent';
import { detectLocaleFromPath } from '../data/siteShell';

interface Props {
  content: ClosingCtaContent;
}

const { content } = Astro.props;
const locale = detectLocaleFromPath(Astro.url.pathname);
---

<section class="closing-cta">
  <div class="container">
    <h2>{content.title}</h2>
    <p>{content.body}</p>
    <div class="closing-cta-buttons">
      <a href={appSignInUrl} class="btn-primary">{content.primaryCta}</a>
      <a href={locale === 'fr' ? '/fr/blog' : '/blog'} class="btn-secondary">{content.secondaryCta}</a>
    </div>
    <p class="closing-note">{content.note}</p>
  </div>
</section>

<style>
  .closing-cta {
        padding: var(--space-20) 0;
    text-align: center;
    background: var(--color-surface);
  }

  .container {
    max-width: var(--width-content-narrow);
  }

  .closing-cta h2 {
    font-size: var(--text-h2);
    font-weight: 900;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .closing-cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .closing-cta-buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  .closing-note {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: var(--width-content-note);
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .closing-cta {
            padding: var(--space-16) 0;
    }

    .closing-cta p {
      font-size: var(--text-base);
    }

    .closing-cta-buttons {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: var(--size-full);
      text-align: center;
    }
  }
</style>
