---
import { appEntryUrl, appSignInUrl } from '../config/site';
import {
  detectLocaleFromPath,
  getLocaleSwitchTarget,
  getNavbarContent,
  type Locale,
} from '../data/siteShell';

interface Props {
  locale?: Locale;
}

const { locale } = Astro.props;
const currentLocale = locale ?? detectLocaleFromPath(Astro.url.pathname);
const content = getNavbarContent(currentLocale);
const localeSwitch = getLocaleSwitchTarget(Astro.url.pathname);
---

<a href="#main-content" class="skip-nav">{content.skipToContent}</a>
<nav class="navbar" aria-label={content.mainNavigation}>
  <div class="container">
    <a href={content.brandHref} class="logo">
      <span class="logo-icon">🤖</span>
      <span class="logo-text">ContentGlowz</span>
    </a>
    <div class="nav-links" id="nav-links">
      {content.primaryLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      {localeSwitch && (
        <a href={localeSwitch.href} class="locale-link" aria-label={localeSwitch.ariaLabel}>
          {localeSwitch.label}
        </a>
      )}
      <a href={appEntryUrl}>{content.appLinkLabel}</a>
      <a href={appSignInUrl} class="mobile-cta">{content.authLinkLabel}</a>
    </div>
    <div class="nav-actions">
      <a href={appSignInUrl} class="cta-button">{content.authLinkLabel}</a>
    </div>
    <button class="hamburger" id="hamburger" aria-expanded="false" aria-controls="nav-links" aria-label={content.toggleNavigationMenu}>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<style>
  .skip-nav {
    position: absolute;
    inset-block-start: -100%;
    inset-inline-start: var(--space-4);
    z-index: var(--z-index-sticky);
    background: var(--color-primary);
    color: var(--color-text-on-dark);
        padding: var(--space-3) var(--space-6);
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    font-weight: 600;
    transition: inset-block-start var(--duration-base);
  }

  .skip-nav:focus {
    inset-block-start: 0;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: var(--z-index-floating);
    background: var(--color-surface-navbar);
    backdrop-filter: var(--surface-backdrop-blur);
    border-bottom: calc(var(--space-1) / 4) solid var(--color-border-subtle);
        padding: var(--space-4) 0;
  }

  .container {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-width: 0;
    padding: 0 var(--space-4);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-h3);
    font-weight: 800;
    color: var(--color-text-primary);
  }

  .logo-icon {
    font-size: var(--text-h2);
  }

  .nav-links {
    display: flex;
    gap: var(--space-8);
    align-items: center;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color var(--duration-base);
  }

  .locale-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: calc(var(--space-10) * 0.9);
    padding: var(--space-2) var(--space-3);
    border: calc(var(--space-1) / 4) solid var(--color-border-subtle);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-surface-elevated) 92%, transparent);
    color: var(--color-text-primary) !important;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .mobile-cta {
    color: var(--color-text-on-dark);
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .locale-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary) !important;
  }

  .cta-button {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: var(--color-text-on-dark);
        padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-sm);
    font-weight: 600;
    transition: transform var(--duration-base), box-shadow var(--duration-base);
  }

  .cta-button:hover {
    transform: translateY(var(--motion-lift-sm));
    box-shadow: var(--shadow-primary);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
    width: var(--space-12);
    height: var(--space-12);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    border: calc(var(--space-1) * 0.5) solid var(--color-border-subtle);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-surface-card-glass) 90%, transparent), var(--color-surface-card-glass));
    backdrop-filter: var(--surface-backdrop-blur);
    box-shadow: var(--shadow-card);
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .hamburger:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-lg);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: calc(var(--space-1) * 0.75);
    background: var(--color-text-primary);
    border-radius: var(--radius-sm);
    transition: transform var(--duration-base), opacity var(--duration-base);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: rotate(-45deg);
  }

  .mobile-cta {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      inset-block-start: 100%;
      inset-inline: 0;
      flex-direction: column;
      width: 100%;
      background: var(--color-surface-card-glass);
      backdrop-filter: var(--surface-backdrop-blur);
      padding: var(--space-6) var(--space-4);
      gap: var(--space-4);
      border-bottom: calc(var(--space-1) / 4) solid var(--color-border-subtle);
    }

    .nav-links.open {
      display: flex;
    }

    .hamburger {
      display: flex;
    }

    .cta-button {
      display: none;
    }

    .mobile-cta {
      display: block;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      color: var(--color-text-on-dark) !important;
            padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-sm);
      font-weight: 600;
      text-align: center;
      margin-top: var(--space-2);
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    navLinks?.classList.toggle('open');
  });
</script>
