---
import { appEntryUrl, appSignInUrl } from '../config/site';
import type { HeroContent } from '../data/homepageContent';

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;
---

<section id="main-content" class="hero">
  <div class="hero-bg"></div>
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        {content.titlePrefix}{' '}
        <span class="gradient-text rotating-words" aria-label={content.ariaLabel}>
          {content.rotatingWords.map((word, index) => (
            <span class:list={['word', { active: index === 0 }]} aria-hidden="true">{word}</span>
          ))}
        </span>{'.'}<br/>{content.titleSuffix}
      </h1>
      <p class="hero-subtitle">{content.subtitle}</p>
      <div class="hero-cta">
        <a href={appSignInUrl} class="btn-primary">{content.primaryCta}</a>
        <a href={appEntryUrl} class="btn-secondary">{content.secondaryCta}</a>
      </div>
      <div class="hero-stats">
        {content.stats.map((stat, index) => (
          <div class="stat-group">
            <div class="stat">
              <span class="stat-number">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
            {index < content.stats.length - 1 && <div class="stat-divider"></div>}
          </div>
        ))}
      </div>
      <p class="hero-trust">{content.trust}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: calc(var(--space-20) * 2) 0 var(--space-24);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 50%, color-mix(in srgb, var(--color-primary) 10%, transparent) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--color-secondary) 10%, transparent) 0%, transparent 50%);
    z-index: var(--z-index-backdrop);
  }

  .hero-content {
    max-width: calc(var(--container-max-width) - var(--space-24) - var(--space-12));
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-size: var(--text-h1);
    font-weight: 900;
    line-height: var(--leading-hero);
    margin-bottom: var(--space-6);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
    position: relative;
    height: calc(var(--text-h1) * var(--leading-tight));
  }

  .rotating-words {
    --hero-word-cycle: calc(var(--duration-slow) * 40);

    display: inline-block;
    vertical-align: top;
  }

  .word {
    position: absolute;
    opacity: 0;
    animation: rotateWord var(--hero-word-cycle) linear infinite;
  }

  .word:nth-child(1) { animation-delay: var(--space-0); }
  .word:nth-child(2) { animation-delay: calc(var(--hero-word-cycle) * 0.25); }
  .word:nth-child(3) { animation-delay: calc(var(--hero-word-cycle) * 0.5); }
  .word:nth-child(4) { animation-delay: calc(var(--hero-word-cycle) * 0.75); }

  @keyframes rotateWord {
    0% { opacity: 0; transform: translateY(var(--space-5)); }
    2% { opacity: 1; transform: translateY(0); }
    23% { opacity: 1; transform: translateY(0); }
    25% { opacity: 0; transform: translateY(calc(var(--space-5) * -1)); }
    100% { opacity: 0; }
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-10);
    line-height: var(--leading-relaxed);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    margin-bottom: var(--space-12);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-8);
    background: var(--color-surface);
        padding: var(--space-6) var(--space-12);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    max-width: calc(var(--container-max-width) / 2.4);
    margin: 0 auto;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-group {
    display: contents;
  }

  .stat-number {
    font-size: var(--text-h2);
    font-weight: 900;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .stat-divider {
    align-self: stretch;
    min-height: var(--space-10);
    border-left: thin solid var(--color-surface-subtle);
  }

  .hero-trust {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-superwide);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--hero-mobile-padding-y) 0 var(--space-12);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }

    .hero-cta {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      inline-size: 100%;
      text-align: center;
    }

    .hero-stats {
      gap: var(--space-3);
            padding: var(--space-4) var(--space-5);
      max-inline-size: 100%;
    }

    .stat-number {
      font-size: var(--text-h3);
    }
  }
</style >
