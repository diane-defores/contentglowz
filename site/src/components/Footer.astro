---
import {
  detectLocaleFromPath,
  getFooterContent,
  getLocaleSwitchTarget,
  type Locale,
} from '../data/siteShell';

interface Props {
  locale?: Locale;
}

const { locale } = Astro.props;
const currentLocale = locale ?? detectLocaleFromPath(Astro.url.pathname);
const content = getFooterContent(currentLocale);
const localeSwitch = getLocaleSwitchTarget(Astro.url.pathname);
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href={content.brandHref} class="logo">
          <span class="logo-icon">🤖</span>
          <span class="logo-text">ContentGlowz</span>
        </a>
        <p class="tagline">{content.tagline}</p>
        {localeSwitch && (
          <a href={localeSwitch.href} class="locale-switch" aria-label={localeSwitch.ariaLabel}>
            {localeSwitch.label}
          </a>
        )}
        <!-- Social links: add real URLs when available -->
      </div>

      <div class="footer-links">
        {content.linkGroups.map((group) => (
          <div class="link-column">
            <h4>{group.heading}</h4>
            <ul>
              {group.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 ContentGlowz. {content.rightsReserved}</p>
      <div class="footer-bottom-links">
        {content.bottomLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
        padding: var(--space-16) 0 var(--space-8);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-16);
    margin-bottom: var(--space-12);
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-h3);
    font-weight: 800;
    color: var(--color-text-on-dark);
    margin-bottom: var(--space-4);
  }

  .logo-icon {
    font-size: var(--text-h2);
  }

  .tagline {
    color: var(--color-text-on-dark-muted);
    margin-bottom: var(--space-6);
    line-height: var(--leading-normal);
  }

  .locale-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: calc(var(--space-10) * 0.9);
    padding: var(--space-2) var(--space-3);
    border: calc(var(--space-1) / 4) solid var(--color-border-dark-subtle);
    border-radius: var(--radius-pill);
    color: var(--color-text-on-dark);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: border-color var(--duration-base), color var(--duration-base);
  }

  .locale-switch:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .social-links {
    display: flex;
    gap: var(--space-4);
  }

  .social-links a {
    inline-size: var(--space-10);
    block-size: var(--space-10);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-overlay-dark);
    border-radius: var(--radius-sm);
    color: var(--color-text-on-dark);
    transition: background var(--duration-slow), transform var(--duration-slow);
  }

  .social-links a:hover {
    background: var(--color-primary);
    transform: translateY(calc(var(--space-1) * -0.75));
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .link-column h4 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text-on-dark);
  }

  .link-column ul {
    list-style: none;
  }

  .link-column li {
    margin-bottom: var(--space-3);
  }

  .link-column a {
    color: var(--color-text-on-dark-muted);
    transition: color var(--duration-slow);
  }

  .link-column a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    border-top: calc(var(--space-1) / 4) solid var(--color-border-dark-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: var(--color-text-on-dark-faint);
    font-size: var(--text-sm);
  }

  .footer-bottom-links {
    display: flex;
    gap: var(--space-8);
  }

  .footer-bottom-links a {
    color: var(--color-text-on-dark-faint);
    font-size: var(--text-sm);
    transition: color var(--duration-slow) var(--ease-standard);
  }

  .footer-bottom-links a:hover {
    color: var(--color-text-on-dark);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }

    .footer-bottom-links {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
