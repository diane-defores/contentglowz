---
import type { ProblemContent } from '../data/homepageContent';

interface Props {
  content: ProblemContent;
}

const { content } = Astro.props;
---

<section class="problem-section">
  <div class="container">
    <div class="problem-content">
      <p class="problem-label">{content.label}</p>
      <h2 class="problem-title" set:html={content.title}></h2>
      <div class="problem-list">
        {content.items.map((item) => (
          <div class="problem-item">
            <span class="problem-icon">{item.icon}</span>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
      <p class="problem-transition">{content.transition}</p>
    </div>
  </div>
</section>

<style>
  .problem-section {
        padding: var(--space-20) 0 var(--space-12);
    background: var(--color-surface-subtle);
  }

  .problem-content {
    max-width: calc(var(--space-20) * 8.75);
    margin: 0 auto;
    text-align: center;
  }

  .problem-label {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-4);
  }

  .problem-title {
    font-size: var(--text-h2);
    font-weight: 900;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-10);
    color: var(--color-text-primary);
  }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
    text-align: left;
  }

  .problem-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--color-surface);
        padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .problem-icon {
    font-size: var(--text-h3);
    flex-shrink: 0;
    line-height: var(--leading-relaxed);
  }

  .problem-item p {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .problem-transition {
    font-size: var(--text-lg);
    font-weight: 700;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (max-width: 768px) {
    .problem-section {
            padding: var(--space-12) 0 var(--space-8);
    }

    .problem-item {
      padding: var(--space-4);
    }
  }
</style>
