---
import { siteUrl } from '../config/site';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  publishDate?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = "AI content pipeline — generate, review, and publish multi-format content",
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  publishDate,
  author = 'ContentFlow Team',
  tags = [],
  noindex = false,
} = Astro.props;

const resolvedSiteUrl = Astro.site?.toString().replace(/\/$/, '') ?? siteUrl;
const canonical = canonicalUrl ?? `${resolvedSiteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${resolvedSiteUrl}${ogImage}`;

const articleSchema = ogType === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImageAbsolute,
  "author": { "@type": "Person", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "ContentFlow",
    "url": resolvedSiteUrl,
  },
  "datePublished": publishDate?.toISOString(),
  "keywords": tags.join(', '),
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
} : null;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ContentFlow",
  "url": resolvedSiteUrl,
  "description": "AI content pipeline — generate, review, and publish multi-format content",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ContentFlow",
  "url": resolvedSiteUrl,
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ContentFlow" />
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

    <!-- Favicon & theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#3b82f6" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- ContentFlow Analytics (cookie-free, production only) -->
    {import.meta.env.PROD && (
      <script defer src="https://api.contentflow.com/a/s.js"></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* =============================================
     CONTENTFLOW DESIGN TOKENS
     Single source of truth for all visual values
     ============================================= */
  :root {
    /* --- Brand colors --- */
    --color-primary: #3b82f6;
    --color-primary-dark: #2563eb;
    --color-secondary: #8b5cf6;
    --color-accent: #06b6d4;

    /* --- Neutral palette --- */
    --color-dark: #0f172a;
    --color-gray: #64748b;
    --color-light-gray: #f1f5f9;
    --color-light-blue: #dbeafe;
    --color-white: #ffffff;

    /* --- Semantic text --- */
    --color-text-primary: var(--color-dark);
    --color-text-muted: var(--color-gray);
    --color-text-code: #e2e8f0;

    /* --- Semantic surfaces --- */
    --color-surface: var(--color-white);
    --color-surface-subtle: var(--color-light-gray);
    --color-surface-tint: var(--color-light-blue);
    --color-surface-navbar: rgba(255, 255, 255, 0.95);
    --color-surface-card-glass: rgba(255, 255, 255, 0.96);

    /* --- Borders & overlays --- */
    --color-border-subtle: rgba(0, 0, 0, 0.05);
    --color-border-light: rgba(0, 0, 0, 0.08);
    --color-border-dark-subtle: rgba(255, 255, 255, 0.1);
    --color-overlay-dark: rgba(255, 255, 255, 0.1);

    /* --- Support colors --- */
    --color-code-text: #e2e8f0;
    --color-badge-bg: #fef3c7;
    --color-badge-text: #92400e;

    /* --- Typography --- */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-main: var(--font-sans); /* backward-compat alias */

    /* Scale: base 1rem, ratio 1.25 */
    --text-xs:   0.75rem;   /* 12px — labels, badges, captions */
    --text-sm:   0.875rem;  /* 14px — meta, small body */
    --text-base: 1rem;      /* 16px — body */
    --text-lg:   1.25rem;   /* 20px — lead, section subtitles */
    --text-h3:   1.5rem;    /* 24px — card headings */
    --text-h2:   clamp(2rem, 1.2rem + 3.33vw, 3rem);        /* section heads */
    --text-h1:   clamp(2.2rem, 1.2rem + 4.17vw, 3.5rem);    /* page hero */

    --leading-tight:  1.2;
    --leading-snug:   1.3;
    --leading-normal: 1.6;
    --leading-relaxed: 1.8;

    --tracking-wide:  0.04em;
    --tracking-wider: 0.08em;

    /* --- Spacing (4px base) --- */
    --space-1:  0.25rem;   /* 4px */
    --space-2:  0.5rem;    /* 8px */
    --space-3:  0.75rem;   /* 12px */
    --space-4:  1rem;      /* 16px */
    --space-5:  1.25rem;   /* 20px */
    --space-6:  1.5rem;    /* 24px */
    --space-8:  2rem;      /* 32px */
    --space-10: 2.5rem;    /* 40px */
    --space-12: 3rem;      /* 48px */
    --space-16: 4rem;      /* 64px */
    --space-20: 5rem;      /* 80px */
    --space-24: 6rem;      /* 96px */

    /* --- Border radius --- */
    --radius-sm:   8px;
    --radius-md:   12px;
    --radius-lg:   16px;
    --radius-xl:   20px;
    --radius-2xl:  28px;
    --radius-pill: 9999px;

    /* --- Shadows / Elevation --- */
    --shadow-sm:           0 2px 8px rgba(0, 0, 0, 0.06);
    --shadow-card:         0 4px 20px rgba(0, 0, 0, 0.08);
    --shadow-card-hover:   0 8px 30px rgba(0, 0, 0, 0.12);
    --shadow-card-lg:      0 12px 40px rgba(0, 0, 0, 0.15);
    --shadow-primary:      0 4px 15px rgba(59, 130, 246, 0.3);
    --shadow-primary-hover: 0 8px 25px rgba(59, 130, 246, 0.4);

    /* --- Motion --- */
    --duration-instant: 0.12s;
    --duration-fast:    0.15s;
    --duration-base:    0.2s;
    --duration-slow:    0.3s;
    --ease-standard:    ease;
    --ease-out:         ease-out;
    --ease-spring:      cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* =============================================
     BASE RESET & GLOBAL STYLES
     ============================================= */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    background-color: var(--color-surface);
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* --- Layout utilities --- */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* --- Button system --- */
  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
    padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    transition: transform var(--duration-base), box-shadow var(--duration-base);
    box-shadow: var(--shadow-primary);
    display: inline-block;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-primary-hover);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-primary);
    padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    border: 2px solid var(--color-primary);
    transition: background var(--duration-base), color var(--duration-base);
    display: inline-block;
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
  }

  /* --- Focus — WCAG 2.4.11 --- */
  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html {
      scroll-behavior: auto;
    }
  }
</style>
