---
import { siteUrl } from '../config/site';
import themeTokens from '../../../contentflow_theme.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  publishDate?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = "AI content pipeline — generate, review, and publish multi-format content",
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  publishDate,
  author = 'ContentFlow Team',
  tags = [],
  noindex = false,
} = Astro.props;

const resolvedSiteUrl = Astro.site?.toString().replace(/\/$/, '') ?? siteUrl;
const canonical = canonicalUrl ?? `${resolvedSiteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${resolvedSiteUrl}${ogImage}`;

const articleSchema = ogType === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImageAbsolute,
  "author": { "@type": "Person", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "ContentFlow",
    "url": resolvedSiteUrl,
  },
  "datePublished": publishDate?.toISOString(),
  "keywords": tags.join(', '),
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
} : null;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ContentFlow",
  "url": resolvedSiteUrl,
  "description": "AI content pipeline — generate, review, and publish multi-format content",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ContentFlow",
  "url": resolvedSiteUrl,
};

const {
  colors,
  surfaces,
  typography,
  spacing,
  radius,
  shadow,
  motion,
  components,
  layout,
  breakpoints,
} = themeTokens;
const themeCssVars = `
  :root {
    --color-primary: ${colors.primary};
    --color-primary-dark: ${colors.primaryDark};
    --color-secondary: ${colors.secondary};
    --color-accent: ${colors.accent};
    --color-success: ${colors.success};
    --color-warning: ${colors.warning};
    --color-orange: ${colors.orange};
    --color-green: ${colors.green};
    --color-error: ${colors.error};
    --color-dark: ${colors.dark};
    --color-gray: ${colors.gray};
    --color-light-gray: ${colors.lightGray};
    --color-light-blue: ${colors.lightBlue};
    --color-white: ${colors.white};
    --color-text-primary: var(--color-dark);
    --color-text-muted: var(--color-gray);
    --color-text-code: ${colors.codeText};
    --color-surface: ${surfaces.light.surface};
    --color-surface-subtle: ${surfaces.light.mutedSurface};
    --color-surface-tint: ${surfaces.light.surfaceTint};
    --color-surface-navbar: rgba(255, 255, 255, 0.95);
    --color-surface-card-glass: rgba(255, 255, 255, 0.96);
    --color-border-subtle: ${surfaces.light.borderSubtle};
    --color-border-light: ${surfaces.light.borderLight};
    --color-border-dark-subtle: ${surfaces.dark.borderSubtle};
    --color-overlay-dark: rgba(255, 255, 255, 0.1);
    --color-text-on-dark: rgba(255, 255, 255, 1);
    --color-text-on-dark-muted: rgba(255, 255, 255, 0.7);
    --color-text-on-dark-faint: rgba(255, 255, 255, 0.6);
    --color-code-text: ${colors.codeText};
    --color-badge-bg: ${colors.badgeBg};
    --color-badge-text: ${colors.badgeText};
    --font-sans: ${typography.fontSans};
    --font-main: var(--font-sans);
    --text-xs: ${typography.textXs};
    --text-sm: ${typography.textSm};
    --text-base: ${typography.textBase};
    --text-lg: ${typography.textLg};
    --text-h3: ${typography.textH3};
    --text-h2: ${typography.textH2};
    --text-h1: ${typography.textH1};
    --leading-tight: ${typography.leadingTight};
    --leading-snug: ${typography.leadingSnug};
    --leading-normal: ${typography.leadingNormal};
    --leading-relaxed: ${typography.leadingRelaxed};
    --tracking-wide: ${typography.trackingWide};
    --tracking-wider: ${typography.trackingWider};
    --space-0: ${spacing[0]};
    --space-1: ${spacing[1]};
    --space-2: ${spacing[2]};
    --space-3: ${spacing[3]};
    --space-4: ${spacing[4]};
    --space-5: ${spacing[5]};
    --space-6: ${spacing[6]};
    --space-8: ${spacing[8]};
    --space-10: ${spacing[10]};
    --space-12: ${spacing[12]};
    --space-16: ${spacing[16]};
    --space-20: ${spacing[20]};
    --space-24: ${spacing[24]};
    --space-mobile-2: ${spacing.mobile[2]};
    --space-mobile-3: ${spacing.mobile[3]};
    --space-mobile-4: ${spacing.mobile[4]};
    --space-mobile-5: ${spacing.mobile[5]};
    --space-mobile-6: ${spacing.mobile[6]};
    --space-mobile-8: ${spacing.mobile[8]};
    --space-mobile-10: ${spacing.mobile[10]};
    --space-mobile-scale: ${spacing.densityScale?.mobile};
    --space-density-scale: ${spacing.densityScale?.desktop};
    --radius-sm: ${radius.sm};
    --radius-md: ${radius.md};
    --radius-lg: ${radius.lg};
    --radius-xl: ${radius.xl};
    --radius-2xl: ${radius['2xl']};
    --radius-pill: ${radius.pill};
    --shadow-sm: ${shadow.sm};
    --shadow-card: ${shadow.card};
    --shadow-card-hover: ${shadow.cardHover};
    --shadow-card-lg: ${shadow.cardLg};
    --shadow-primary: ${shadow.primary};
    --shadow-primary-hover: ${shadow.primaryHover};
    --duration-instant: ${motion.instant};
    --duration-fast: ${motion.fast};
    --duration-base: ${motion.base};
    --duration-slow: ${motion.slow};
    --ease-standard: ${motion.standard};
    --ease-out: ${motion.out};
    --ease-spring: ${motion.spring};
    --container-max-width: ${layout.containerMaxWidth};
    --section-gap: ${layout.sectionGap};
    --hero-gap: ${layout.heroGap};
    --cta-width: ${layout.ctaWidth};
    --section-padding: ${components.card.padding};
    --card-radius: ${components.card.radius};
    --card-compact-radius: ${components.card.compactRadius};
    --card-compact-padding: ${components.card.compactPadding};
    --button-radius: ${components.button.radius};
    --button-padding-x: ${components.button.paddingX};
    --button-padding-y: ${components.button.paddingY};
    --button-compact-padding-y: ${components.button.compactPaddingY};
    --input-radius: ${components.input.radius};
    --input-radius-compact: ${components.input.radiusCompact};
    --radius-nav: ${components.nav.radius};
    --badge-radius: ${components.badge.radius};
    --breakpoint-mobile: ${breakpoints.mobile}px;
    --breakpoint-tablet: ${breakpoints.tablet}px;
    --breakpoint-desktop: ${breakpoints.desktop}px;
    --mobile-density-scale: ${spacing.densityScale?.mobile};
    --desktop-density-scale: ${spacing.densityScale?.desktop};
  }
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ContentFlow" />
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

    <!-- Favicon & theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content={colors.primary} />
    <style is:global set:html={themeCssVars}></style>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- ContentFlow Analytics (cookie-free, production only) -->
    {import.meta.env.PROD && (
      <script defer src="https://api.contentflow.com/a/s.js"></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* =============================================
     CONTENTFLOW DESIGN TOKENS
     Single source of truth for all visual values
     ============================================= */
  /* =============================================
     BASE RESET & GLOBAL STYLES
     ============================================= */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    background-color: var(--color-surface);
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* --- Layout utilities --- */
  .container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  @media (max-width: var(--breakpoint-mobile)) {
    .container {
      padding: 0 var(--space-mobile-4);
    }

    .section-header {
      margin-bottom: var(--section-gap);
    }

    .section-header p {
      font-size: calc(var(--text-base) * var(--mobile-density-scale));
    }
  }

  /* --- Button system --- */
  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
    padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    transition: transform var(--duration-base), box-shadow var(--duration-base);
    box-shadow: var(--shadow-primary);
    display: inline-block;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-primary-hover);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-primary);
    padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--text-base);
    border: 2px solid var(--color-primary);
    transition: background var(--duration-base), color var(--duration-base);
    display: inline-block;
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
  }

  /* --- Focus — WCAG 2.4.11 --- */
  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html {
      scroll-behavior: auto;
    }
  }
</style>
