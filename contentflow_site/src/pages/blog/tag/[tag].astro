---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Map<string, string>();

  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => {
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      if (!tags.has(slug)) tags.set(slug, tag);
    });
  });

  return Array.from(tags.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: posts
        .filter((p) => p.data.tags?.some((t) => t.toLowerCase().replace(/\s+/g, '-') === slug))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { label, posts } = Astro.props;
---

<Layout
  title={`${label} — ContentFlow Blog`}
  description={`Articles tagged "${label}" on the ContentFlow blog.`}
>
  <Navbar />

  <header class="tag-header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <a href="/blog">Blog</a>
      <span>›</span>
      <span>{label}</span>
    </nav>
  </header>

  <main id="main-content" class="tag-main">
    <h1>Tag: {label}</h1>
    <p class="count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>

    <div class="posts-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          {post.data.cover && (
            <img src={post.data.cover} alt={`Illustration for ${post.data.title}`} width="400" height="210" />
          )}
          <div class="post-card-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>

    <a href="/blog" class="back-link">← Back to Blog</a>
  </main>

  <Footer />
</Layout>

<style>
  .tag-header {
    padding: 5rem 2rem 1.5rem;
    border-bottom: 1px solid var(--color-light-gray);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-gray);
    max-width: 900px;
    margin: 0 auto;
  }

  .breadcrumb a:hover { color: var(--color-primary); }

  .tag-main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .tag-main h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .count {
    color: var(--color-gray);
    margin-bottom: 2rem;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .post-card {
    display: flex;
    gap: 1.5rem;
    border: 1px solid var(--color-light-gray);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .post-card img {
    width: 200px;
    height: 140px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-card-body {
    padding: 1.25rem 1.25rem 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-card-body h2 {
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .post-card-body p {
    font-size: 0.875rem;
    color: var(--color-gray);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-body time {
    font-size: 0.8rem;
    color: var(--color-gray);
    margin-top: auto;
  }

  .back-link {
    color: var(--color-gray);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-primary); }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }

    .post-card img {
      width: 100%;
      height: 180px;
    }

    .post-card-body {
      padding: 1rem;
    }
  }
</style>
