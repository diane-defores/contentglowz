---
import Layout from '../layouts/Layout.astro';
import { appEntryUrl, appSignInUrl } from '../config/site';
---

<Layout
  title="Opening ContentFlow App"
  description="Redirecting to the ContentFlow app."
  noindex={true}
>
  <section class="redirect-shell">
    <div class="redirect-card">
      <p class="eyebrow">Open app</p>
      <h1>Opening the app entry…</h1>
      <p>
        The old website handoff has been retired. ContentFlow now opens the app
        directly on the app domain, where sign-in and session restore both happen.
      </p>
      <div class="actions">
        <a class="btn-primary" href={appEntryUrl}>Open app entry</a>
        <a class="btn-secondary" href={appSignInUrl}>Go to sign-in</a>
      </div>
    </div>
  </section>

  <script define:vars={{ appEntryUrl }}>
    window.location.replace(appEntryUrl);
  </script>
</Layout>

<style>
  .redirect-shell {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--color-secondary) 12%, transparent), transparent 45%),
      linear-gradient(180deg, #f8f7ff 0%, #f1efff 100%);
  }

  .redirect-card {
    width: min(100%, 560px);
    padding: 2rem;
    border-radius: 24px;
    background: var(--color-surface-card-glass);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-card-lg);
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2rem, 1.4rem + 2vw, 2.8rem);
    margin-bottom: 1rem;
  }

  p {
    color: var(--color-gray);
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
